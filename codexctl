  cat <<EOF
Usage: $CLI_NAME <command> [options]

Commands:
  build      Build agent images
  run        Create/start a container for the current directory
  runtime    Manage coding runtimes inside an existing container
  use        Select the preferred runtime for an existing container
  refresh    Refresh agentctl-managed files in an existing container
  system-manifest  Print a container package manifest
  upgrade    Recreate a container from the latest image while preserving config
  auth       Run OpenAI device auth flow and store in Keychain
  exec       Exec into a running container (default: bash)
  su-exec    Exec into a running container as root (default: bash)
  start      Start a container
  stop       Stop a running container
  restart    Restart a container
  rm         Remove a container
  ls         List containers
  images     List local agent images or prune old timestamp tags

Run "$CLI_NAME <command> --help" for command-specific options.
EOF
}

usage_build() {
  cat <<EOF
Usage: $CLI_NAME build [--image NAME] [--rebuild] [--snapshot] [--pull-base] [--refresh-base]

Options:
  --image NAME  Local image name to build (for example: agent-plain, agent-python, agent-swift, agent-my-team)
  --rebuild     Rebuild images even if they already exist (disables build cache only; does not refresh FROM tags)
  --snapshot    Add a fresh UTC timestamp tag for existing images without rebuilding
  --pull-base     Pull the base image before building (preferred way to refresh remote FROM tags)
  --refresh-base  Remove the base image first so it is re-fetched

Each successful build keeps the stable image name (for example `agent-plain`) and
also adds an immutable UTC timestamp tag (for example `agent-plain:20260313-154500`).
Local image names follow this convention:
  agent-plain   -> DockerFile
  agent-<name>  -> DockerFile.<name>

Legacy aliases `codex`, `codex-python`, and `codex-swift` are accepted as inputs.

When a local Dockerfile uses FROM another local agent image, $CLI_NAME builds the
dependency chain first.
EOF
}

