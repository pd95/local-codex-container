  "$CONTAINER_CMD" exec -i "$name" "${SETPRIV_ARGS[@]}" sh -s -- "$profile" <<'SH'
profile="${1:-gpt-oss}"
config_file=""
provider=""
base_url=""
configured_api_url=""
configured_ok=0
gateway=""
gateway_api_url=""
gateway_ok=0

for candidate in /home/coder/.codex/config.toml /etc/codexctl/config.toml; do
  if [ -f "$candidate" ]; then
    config_file="$candidate"
    break
  fi
done

if [ -n "$config_file" ]; then
  provider="$(awk -v profile="$profile" '
    /^\[profiles\.[^]]+\][[:space:]]*$/ {
      current=$0
      sub(/^\[profiles\./, "", current)
      sub(/\][[:space:]]*$/, "", current)
      in_profile=(current == profile)
      next
    }
    /^\[[^]]+\][[:space:]]*$/ {
      in_profile=0
    }
    in_profile && /^[[:space:]]*model_provider[[:space:]]*=/ {
      line=$0
      sub(/^[^"]*"/, "", line)
      sub(/".*$/, "", line)
      print line
      exit
    }
  ' "$config_file")"
  if [ -n "$provider" ]; then
    base_url="$(awk -v provider="$provider" '
      /^\[model_providers\.[^]]+\][[:space:]]*$/ {
        current=$0
        sub(/^\[model_providers\./, "", current)
        sub(/\][[:space:]]*$/, "", current)
        in_provider=(current == provider)
        next
      }
      /^\[[^]]+\][[:space:]]*$/ {
        in_provider=0
      }
      in_provider && /^[[:space:]]*base_url[[:space:]]*=/ {
        line=$0
        sub(/^[^"]*"/, "", line)
        sub(/".*$/, "", line)
        print line
        exit
      }
    ' "$config_file")"
  fi
  if [ -z "$base_url" ]; then
    base_url="$(awk '
      /^[[:space:]]*base_url[[:space:]]*=/ {
        line=$0
        sub(/^[^"]*"/, "", line)
        sub(/".*$/, "", line)
        print line
        exit
      }
    ' "$config_file")"
  fi
fi

if [ -n "$base_url" ]; then
  case "$base_url" in
    http://*|https://*)
      configured_api_url="$(printf '%s\n' "$base_url" | awk -F/ 'NF >= 3 { print $1 "//" $3 "/api/version"; exit }')"
      if [ -n "$configured_api_url" ] && curl -fsS --max-time 3 "$configured_api_url" >/dev/null 2>&1; then
        configured_ok=1
      fi
      ;;
  esac
fi

gateway="$(awk '
  function hex2dec(hex,   i, c, n, v) {
    n = 0
    hex = toupper(hex)
    for (i = 1; i <= length(hex); i++) {
      c = substr(hex, i, 1)
      v = index("0123456789ABCDEF", c) - 1
      if (v < 0) {
        return ""
      }
      n = (n * 16) + v
    }
    return n
  }
  $2 == "00000000" && length($3) == 8 {
    printf "%s.%s.%s.%s\n",
      hex2dec(substr($3, 7, 2)),
      hex2dec(substr($3, 5, 2)),
      hex2dec(substr($3, 3, 2)),
      hex2dec(substr($3, 1, 2))
    exit
  }
' /proc/net/route 2>/dev/null || true)"
if [ -n "$gateway" ]; then
  gateway_api_url="http://${gateway}:11434/api/version"
  if curl -fsS --max-time 3 "$gateway_api_url" >/dev/null 2>&1; then
    gateway_ok=1
  fi
fi

printf 'config_file=%s\n' "$config_file"
printf 'base_url=%s\n' "$base_url"
printf 'configured_api_url=%s\n' "$configured_api_url"
printf 'configured_ok=%s\n' "$configured_ok"
printf 'gateway=%s\n' "$gateway"
printf 'gateway_api_url=%s\n' "$gateway_api_url"
printf 'gateway_ok=%s\n' "$gateway_ok"
SH
}

local_model_preflight() {
  local name="$1"
  local mode="$2"
  local output
  local config_file=""
  local base_url=""
  local configured_api_url=""
  local configured_ok="0"
  local gateway=""
  local gateway_api_url=""
  local gateway_ok="0"
  local line
  local key
  local value
  local message=""
  local remediation_host=""
  local remediation=""

  if ! output="$(local_model_preflight_info "$name" "$profile")"; then
    message="Unable to run local-model preflight inside container: $name"
    case "$mode" in
      warn) warn "$message"; return 0 ;;
      *) die "$message" ;;
    esac
  fi

  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      config_file) config_file="$value" ;;
      base_url) base_url="$value" ;;
      configured_api_url) configured_api_url="$value" ;;
      configured_ok) configured_ok="$value" ;;
      gateway) gateway="$value" ;;
      gateway_api_url) gateway_api_url="$value" ;;
      gateway_ok) gateway_ok="$value" ;;
    esac
  done <<< "$output"

  remediation_host="$gateway"
  if [ -z "$remediation_host" ] && [ -n "$configured_api_url" ]; then
    remediation_host="$(printf '%s\n' "$configured_api_url" | awk -F'[/:]' 'NF >= 4 { print $4; exit }')"
  fi
  if [ -n "$remediation_host" ]; then
    remediation="$(cat <<EOF

Host-side fixes:
- Start a second Ollama listener:
  OLLAMA_HOST=${remediation_host} ollama serve

- Proxy localhost with socat (needs \`brew install socat\`):
  socat TCP-LISTEN:11434,fork,bind=${remediation_host} TCP:127.0.0.1:11434
EOF
)"
  fi

  if [ "$configured_ok" = "1" ]; then
    return 0
  fi

  if [ "$gateway_ok" = "1" ]; then
    if [ -n "$configured_api_url" ]; then
      message="Local Ollama is reachable from $name at $gateway_api_url, but Codex is configured to use $configured_api_url from ${config_file:-config.toml}.

Update ${config_file:-/home/coder/.codex/config.toml} to use http://${gateway}:11434/v1.
See README.md 'Local model connectivity'."
    else
      message="Local Ollama is reachable from $name at $gateway_api_url, but Codex does not have a usable local base_url in ${config_file:-config.toml}.

Set base_url to http://${gateway}:11434/v1.
See README.md 'Local model connectivity'."
    fi
  else
    if [ -n "$configured_api_url" ] && [ -n "$gateway_api_url" ]; then
      message="Local Ollama is not reachable from $name.

Tried:
- Configured endpoint: $configured_api_url
- Detected host gateway: $gateway_api_url

Expose or proxy Ollama onto the container network.
See README.md 'Local model connectivity'.${remediation}"
    elif [ -n "$configured_api_url" ]; then
      message="Local Ollama is not reachable from $name.

Tried:
- Configured endpoint: $configured_api_url

Expose or proxy Ollama onto the container network.
See README.md 'Local model connectivity'.${remediation}"
    elif [ -n "$gateway_api_url" ]; then
      message="Unable to determine a usable Ollama base_url from ${config_file:-config.toml}, and the detected host gateway is also unreachable.

Tried:
- Detected host gateway: $gateway_api_url

See README.md 'Local model connectivity'.${remediation}"
    else
      message="Unable to determine a usable Ollama endpoint from ${config_file:-config.toml}, and no default host gateway probe succeeded.

See README.md 'Local model connectivity'.${remediation}"
    fi
  fi

  case "$mode" in
    warn) warn "$message" ;;
    *) die "$message" ;;
  esac
}

local_model_pre_exec() {
  local name="$1"
  local_model_preflight "$name" strict
}

update_codex_pre_exec() {
  local name="$1"
  local cmd='npm install -g @openai/codex --omit=dev --no-fund --no-audit'
  echo "Updating @openai/codex in container: $name" >&2
  if "$CONTAINER_CMD" exec -it -u 0 "$name" sh -lc "$cmd"; then
    return 0
  fi
  warn "Root-level update failed for $name; retrying as container user"
  "$CONTAINER_CMD" exec -it "$name" sh -lc "$cmd"
}

openai_update_pre_exec() {
  local name="$1"
  update_codex_pre_exec "$name"
  openai_pre_exec "$name"
}

local_model_update_pre_exec() {
  local name="$1"
  update_codex_pre_exec "$name"
  local_model_preflight "$name" strict
}

run_cmd() {
  local name=""
  local image=""
  local runtime=""
  local install_runtime=0
  local openai=0
  local auth=0
  local update=0
  local temp=0
  local shell=0
  local reset_config=0
  local profile="${DEFAULT_CODEX_PROFILE}"
  local profile_set=0
  local read_only=0
  local cpu=""
  local mem=""
  local workdir=""
  local -a cmd_override=()
  local cmd_override_set=0
  local shell_set=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --image) image="$2"; shift 2 ;;
      --workdir) workdir="$2"; shift 2 ;;
      --runtime) runtime="$2"; shift 2 ;;
      --install-runtime) install_runtime=1; shift ;;
      --openai) openai=1; shift ;;
      --auth) auth=1; shift ;;
      --reset-config) reset_config=1; shift ;;
      --update) update=1; shift ;;
      --temp) temp=1; shift ;;
      --read-only) read_only=1; shift ;;
      --shell) shell=1; shell_set=1; shift ;;
      --profile) profile="$2"; profile_set=1; shift 2 ;;
      --cmd) shift; cmd_override_set=1; cmd_override=("$@"); break ;;
      --cpu) cpu="$2"; shift 2 ;;
      --mem) mem="$2"; shift 2 ;;
      --help) usage_run; return 0 ;;
      *) die "Unknown option for run: $1" ;;
    esac
  done

  require_container
  if [ "$shell_set" -eq 1 ] && [ "$cmd_override_set" -eq 1 ]; then
    die "Cannot combine --shell with --cmd"
  fi
  if [ "$cmd_override_set" -eq 1 ] && [ "${#cmd_override[@]}" -eq 0 ]; then
    die "Missing command after --cmd"
  fi
  if [ "$cmd_override_set" -eq 1 ] && [ "${#cmd_override[@]}" -eq 1 ]; then
    case "${cmd_override[0]}" in
      *[[:space:]]*) cmd_override=("$DEFAULT_SHELL" "-lc" "${cmd_override[0]}") ;;
    esac
  fi
  if [ "$auth" -eq 1 ] && [ "$openai" -eq 0 ]; then
    die "--auth requires --openai"
  fi
  if [ "$install_runtime" -eq 1 ] && [ -z "$runtime" ]; then
    die "--install-runtime requires --runtime"
  fi
  if [ -n "$runtime" ] && [ "$openai" -eq 1 ] && [ "$runtime" != "$OPENAI_RUNTIME_ID" ]; then
    die "--openai currently requires --runtime $OPENAI_RUNTIME_ID"
  fi
  if [ -n "$runtime" ] && [ "$runtime" != "codex" ] && [ "$profile_set" -eq 1 ]; then
    die "--profile only applies to the codex runtime"
  fi

  if [ -z "$workdir" ]; then
    workdir="$PWD"
  fi
  if [ ! -d "$workdir" ]; then
    die "Workdir not found: $workdir"
  fi
  workdir="$(CDPATH= cd -- "$workdir" && pwd)"

  [ -n "$image" ] || image="$DEFAULT_IMAGE"
  image="$(image_ref_for_runtime "$image")"
  if [ -z "$name" ] && [ "$temp" -eq 0 ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX" "$workdir")"
  fi
  if [ "$temp" -eq 0 ] && [ -n "$name" ] && container_exists "$name" && { [ -n "$cpu" ] || [ -n "$mem" ]; }; then
    die "--cpu and --mem only apply when creating a new container. Use ${CLI_NAME} upgrade --name $name${image:+ --image $image}${cpu:+ --cpu $cpu}${mem:+ --mem $mem} to recreate the container with updated resources"
  fi

  RUN_SELECTED_RUNTIME="$runtime"
  RUN_INSTALL_RUNTIME="$install_runtime"
  RUN_SYNC_OPENAI=0
  RUN_LOCAL_MODEL_PREFLIGHT=0
  RUN_UPDATE_CODEX=0
  if [ "$openai" -eq 1 ]; then
    RUN_SYNC_OPENAI=1
  elif [ "$shell" -eq 0 ] && [ "${#cmd_override[@]}" -eq 0 ] && { [ -z "$runtime" ] || [ "$runtime" = "codex" ]; }; then
    RUN_LOCAL_MODEL_PREFLIGHT=1
  fi
  if [ "$update" -eq 1 ]; then
    RUN_UPDATE_CODEX=1
  fi

  run_mode "$name" "$image" "$temp" "$shell" "$openai" "$auth" "$update" "$cpu" "$mem" "$read_only" "$workdir" "$reset_config" "$profile" ${cmd_override[@]+"${cmd_override[@]}"}
}

auth_cmd() {
  local name=""
  local image="$DEFAULT_IMAGE"
  local runtime="$OPENAI_RUNTIME_ID"

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --image) image="$2"; shift 2 ;;
      --runtime) runtime="$2"; shift 2 ;;
      --help) usage_auth; return 0 ;;
      *) die "Unknown option for auth: $1" ;;
    esac
  done

  require_container
  if [ -z "$name" ]; then
    name="$(default_name "$AUTH_NAME_PREFIX")"
  fi
  image="$(image_ref_for_runtime "$image")"
  run_auth_flow "$image" "$name" "$runtime"
  if [ "$runtime" = "$OPENAI_RUNTIME_ID" ]; then
    echo "Auth updated. Restart any running --openai containers to pick up the new token." >&2
  else
    echo "Auth updated for runtime: $runtime" >&2
  fi
}

upgrade_cmd() {
  local name=""
  local image=""
  local cpu=""
  local mem=""
  local backup_image=""
  local no_backup=0
  local overwrite_config=0
  local current_image=""
  local workdir=""
  local mount_mode=""
  local current_cpu=""
  local current_mem=""
  local read_only=0
  local was_running=0
  local started_for_backup=0
  local inspect_info=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --image) image="$2"; shift 2 ;;
      --cpu) cpu="$2"; shift 2 ;;
      --mem) mem="$2"; shift 2 ;;
      --backup-image) backup_image="$2"; shift 2 ;;
      --no-backup) no_backup=1; shift ;;
      --overwrite-config) overwrite_config=1; shift ;;
      --help) usage_upgrade; return 0 ;;
      *) die "Unknown option for upgrade: $1" ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi
  if [ "$no_backup" -eq 1 ] && [ -n "$backup_image" ]; then
    die "Cannot combine --no-backup with --backup-image"
  fi
  if [ "$no_backup" -eq 0 ]; then
    require_container_backup_support
  fi
  if ! container_exists "$name"; then
    die "Container not found: $name"
  fi

  inspect_info="$("$CONTAINER_CMD" inspect "$name" 2>/dev/null | container_upgrade_info)"
  IFS=$'\t' read -r current_image workdir mount_mode current_cpu current_mem <<<"$inspect_info"
  [ -n "$current_image" ] || die "Unable to determine image for $name"
  [ -n "$workdir" ] || die "Unable to determine /workdir mount source for $name"

  if [ "$mount_mode" = "ro" ]; then
    read_only=1
  elif [ "$mount_mode" != "rw" ]; then
    die "Unable to determine mount mode for $name"
  fi

  [ -n "$image" ] || image="$current_image"
  image="$(image_ref_for_runtime "$image")"
  [ -n "$cpu" ] || cpu="$current_cpu"
  [ -n "$mem" ] || mem="$current_mem"
  image_exists "$image" || die "Image not found: $image"
  [ -e "$workdir" ] || die "Preserved /workdir source does not exist: $workdir"
  [ -d "$workdir" ] || die "Preserved /workdir source is not a directory: $workdir"
  if [ "$no_backup" -eq 0 ] && [ -z "$backup_image" ]; then
    backup_image="$(sanitize_image_name "${name}-backup-$(date -u +%Y%m%d%H%M%S)")"
  fi

  local backup_dir
  local config_backup_file
  local export_file
  local backup_root
  local backup_dockerfile
  backup_dir="$(mktemp -d)"
  config_backup_file="$backup_dir/codex-config.tar"
  export_file="$backup_dir/codex-export.tar"
  backup_root="$backup_dir/rootfs"
  backup_dockerfile="$backup_dir/Dockerfile.backup"
  trap 'cleanup_temp_dir "$backup_dir"' RETURN

  if container_running "$name"; then
    was_running=1
  fi

  if [ "$was_running" -eq 0 ]; then
    echo "Starting container for config backup: $name" >&2
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_backup=1
  fi

  local agents_state=""
  agents_state="$(codex_agents_state "$name")"
  case "$agents_state" in
    symlink|missing) ;;
    file)
      if [ "$overwrite_config" -eq 0 ]; then
        if [ "$started_for_backup" -eq 1 ]; then
          echo "Stopping container: $name" >&2
          "$CONTAINER_CMD" stop "$name" >/dev/null || true
        fi
        die "Container has ~/.codex/AGENTS.md as a regular file. Re-run with --overwrite-config to replace ~/.codex/config.toml and ~/.codex/local_models.json and recreate ~/.codex/AGENTS.md as a symlink to /etc/codexctl/image.md. If no valid AGENTS.md configuration already exists, use ${CLI_NAME} run --name $name --reset-config"
      fi
      echo "Warning: replacing regular ~/.codex/AGENTS.md, ~/.codex/config.toml, and ~/.codex/local_models.json in $name due to --overwrite-config" >&2
      ;;
    other)
      if [ "$overwrite_config" -eq 0 ]; then
        if [ "$started_for_backup" -eq 1 ]; then
          echo "Stopping container: $name" >&2
          "$CONTAINER_CMD" stop "$name" >/dev/null || true
        fi
        die "Container has ~/.codex/AGENTS.md in a non-symlink form. Re-run with --overwrite-config to recreate it as a symlink to /etc/codexctl/image.md. If no valid AGENTS.md configuration already exists, use ${CLI_NAME} run --name $name --reset-config"
      fi
      echo "Warning: replacing non-standard ~/.codex/AGENTS.md in $name due to --overwrite-config" >&2
      ;;
  esac

  echo "Backing up /home/coder/.codex from $name" >&2
  backup_codex_config "$name" "$config_backup_file"

  if [ "$was_running" -eq 1 ] || [ "$started_for_backup" -eq 1 ]; then
    echo "Stopping container: $name" >&2
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi

  if [ "$no_backup" -eq 0 ]; then
    echo "Exporting container state to image: $backup_image" >&2
    "$CONTAINER_CMD" export "$name" --output "$export_file"
    build_backup_image_from_export "$backup_image" "$name" "$export_file" "$backup_root" "$backup_dockerfile"
  else
    echo "Skipping backup image export for $name" >&2
  fi

  echo "Removing container: $name" >&2
  "$CONTAINER_CMD" rm "$name" >/dev/null

  echo "Recreating container: $name" >&2
  local create_cmd=("$CONTAINER_CMD" create -t)
  if [ -n "$cpu" ]; then
    create_cmd+=(-c "$cpu")
  fi
  if [ -n "$mem" ]; then
    create_cmd+=(-m "$mem")
  fi
  local mount_opts="type=bind,src=$workdir,dst=/workdir"
  if [ "$read_only" -eq 1 ]; then
    mount_opts="${mount_opts},readonly"
  fi
  create_cmd+=(
    --name "$name"
    --mount "$mount_opts"
    "$image" sh -c 'sleep infinity'
  )
  "${create_cmd[@]}"

  echo "Starting container: $name" >&2
  "$CONTAINER_CMD" start "$name" >/dev/null

  echo "Restoring /home/coder/.codex into $name" >&2
  restore_codex_config "$name" "$config_backup_file"
  if [ "$overwrite_config" -eq 1 ]; then
    echo "Overwriting config.toml, local_models.json in ~/.codex/ and recreating ~/.codex/AGENTS.md in $name" >&2
    overwrite_codex_config "$name"
  fi

  if [ "$was_running" -eq 0 ]; then
    echo "Stopping container: $name" >&2
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi

  if [ "$no_backup" -eq 0 ]; then
    echo "Upgrade complete: $name (backup image: $backup_image)" >&2
  else
    echo "Upgrade complete: $name (backup skipped)" >&2
  fi
  echo >&2
  echo "If no valid AGENTS.md configuration already exists, reset it with: ${CLI_NAME} run --name $name --reset-config" >&2
  if [ "$no_backup" -eq 0 ]; then
    echo "If everything works as expected, remove the backup image with: ${CLI_NAME} images prune --backup --image $backup_image --keep 0" >&2
  fi
}

exec_cmd() {
  local name=""
  local cmd=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --help) usage_exec; return 0 ;;
      --) shift; cmd=("$@"); break ;;
      --*) die "Unknown option for exec: $1" ;;
      *) cmd=("$@"); break ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  if [ "${#cmd[@]}" -eq 0 ]; then
    cmd=("$DEFAULT_SHELL" "-l")
  fi
  if [ "${#cmd[@]}" -eq 1 ]; then
    case "${cmd[0]}" in
      *[[:space:]]*) cmd=("$DEFAULT_SHELL" "-lc" "${cmd[0]}") ;;
    esac
  fi

  if ! container_running "$name"; then
    die "Container not running: $name"
  fi

  "$CONTAINER_CMD" exec -it "$name" "${SETPRIV_ARGS[@]}" "${cmd[@]}"
}

su_exec_cmd() {
  local name=""
  local cmd=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --help) usage_su_exec; return 0 ;;
      --) shift; cmd=("$@"); break ;;
      --*) die "Unknown option for su-exec: $1" ;;
      *) cmd=("$@"); break ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  if [ "${#cmd[@]}" -eq 0 ]; then
    cmd=("$DEFAULT_SHELL" "-l")
  fi
  if [ "${#cmd[@]}" -eq 1 ]; then
    case "${cmd[0]}" in
      *[[:space:]]*) cmd=("$DEFAULT_SHELL" "-lc" "${cmd[0]}") ;;
    esac
  fi

  if ! container_running "$name"; then
    die "Container not running: $name"
  fi

  "$CONTAINER_CMD" exec -u 0 -it "$name" "${cmd[@]}"
}

simple_name_cmd() {
  local action="$1"
  shift
  local name=""
  local force=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --force) force=1; shift ;;
      --help) usage_simple_name; return 0 ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  case "$action" in
    start) "$CONTAINER_CMD" start "$name" ;;
    stop) "$CONTAINER_CMD" stop "$name" ;;
    restart) "$CONTAINER_CMD" restart "$name" ;;
    rm)
      if [ "$force" -eq 1 ] && container_running "$name"; then
        "$CONTAINER_CMD" stop "$name" >/dev/null
      fi
      "$CONTAINER_CMD" rm "$name"
      ;;
    *) die "Unknown action: $action" ;;
  esac
}

ls_cmd() {
  require_container
  container_list_all | awk '
    NR == 1 { print; next }
    {
      image = $2
      sub(/^.*\//, "", image)
      sub(/[:@].*$/, "", image)
      if (image ~ /^(agent|codex)([[:alnum:]_.-]*|$)/) {
        print
      }
    }
  '
}

cmd="${1:-}"
case "$cmd" in
  build) shift; build_cmd "$@" ;;
  run) shift; run_cmd "$@" ;;
  runtime) shift; runtime_cmd "$@" ;;
  use) shift; use_cmd "$@" ;;
  refresh) shift; refresh_cmd "$@" ;;
  system-manifest) shift; system_manifest_cmd "$@" ;;
  upgrade) shift; upgrade_cmd "$@" ;;
  auth) shift; auth_cmd "$@" ;;
  exec) shift; exec_cmd "$@" ;;
  su-exec) shift; su_exec_cmd "$@" ;;
  start|stop|restart|rm) shift; simple_name_cmd "$cmd" "$@" ;;
  ls) shift; ls_cmd "$@" ;;
  images) shift; images_cmd "$@" ;;
  --help|-h|help|"") usage ;;
  *) die "Unknown command: $cmd" ;;
esac
