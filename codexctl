#!/usr/bin/env bash
set -euo pipefail

CONTAINER_CMD="${CONTAINER_CMD:-container}"
DEFAULT_IMAGE="codex"
DEFAULT_NAME_PREFIX="codex-"
AUTH_NAME_PREFIX="codex-openai-auth-"
DEFAULT_SHELL="${CODEX_SHELL:-bash}"
DEFAULT_CODEX_PROFILE="gpt-oss"
DEFAULT_CODEX_CMD=(codex)
SETPRIV_ARGS=(setpriv --inh-caps=-all --ambient-caps=-all --bounding-set=-all --no-new-privs --)

resolve_script_path() {
  local path="$1"
  while [ -L "$path" ]; do
    local target
    target="$(readlink "$path")"
    if [[ "$target" != /* ]]; then
      path="$(CDPATH= cd -- "$(dirname -- "$path")" && pwd)/$target"
    else
      path="$target"
    fi
  done
  echo "$path"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
KEYCHAIN_SCRIPT="$SCRIPT_DIR/codex-auth-keychain.sh"

die() {
  echo "Error: $*" >&2
  exit 1
}

warn() {
  echo "Warning: $*" >&2
}

require_container() {
  command -v "$CONTAINER_CMD" >/dev/null 2>&1 || die "Missing '$CONTAINER_CMD' command"
}

python_exec() {
  local python_cmd=""
  if command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
  elif command -v python >/dev/null 2>&1; then
    python_cmd="python"
  else
    die "Missing python (python3 or python)"
  fi
  "$python_cmd" -c "$1"
}

container_list_all() {
  "$CONTAINER_CMD" ls -a 2>/dev/null || true
}

container_list_running() {
  "$CONTAINER_CMD" ls 2>/dev/null || true
}

container_exists() {
  container_list_all | grep -q -E "(^|[[:space:]])$1([[:space:]]|$)"
}

container_running() {
  container_list_running | grep -q -E "(^|[[:space:]])$1([[:space:]]|$)"
}

container_mount_mode() {
  local script
  script="$(cat <<'PY'
import json
import sys

try:
    data = json.loads(sys.stdin.read())
except Exception:
    print("unknown")
    sys.exit(0)

if isinstance(data, list) and data:
    data = data[0]

config = data.get("configuration") or data
mounts = config.get("mounts") or []

mode = "unknown"
for mount in mounts:
    target = mount.get("destination") or mount.get("dst") or ""
    if target != "/workdir":
        continue
    opts = mount.get("options") or []
    if isinstance(opts, str):
        opts = [opts]
    mode = "ro" if "ro" in opts else "rw"
    break

print(mode)
PY
)"
  python_exec "$script" || echo "unknown"
}

container_upgrade_info() {
  local script
  script="$(cat <<'PY'
import json
import sys

def lookup(data, *paths):
    for path in paths:
        cur = data
        ok = True
        for part in path:
            if isinstance(cur, dict) and part in cur:
                cur = cur[part]
            else:
                ok = False
                break
        if ok and cur not in (None, ""):
            return cur
    return ""

def string_value(value):
    if isinstance(value, str):
        return value
    if isinstance(value, dict):
        for key in ("name", "reference", "image", "imageName", "id"):
            inner = value.get(key)
            if isinstance(inner, str) and inner:
                return inner
    return ""

try:
    data = json.loads(sys.stdin.read())
except Exception:
    print("\t\t\t\t")
    sys.exit(0)

if isinstance(data, list) and data:
    data = data[0]

config = data.get("configuration") or data
mounts = config.get("mounts") or []

image = string_value(
    lookup(data, ("image", "name"))
    or lookup(config, ("image", "name"))
    or lookup(data, ("image",))
    or lookup(config, ("image",))
    or lookup(data, ("imageReference",))
    or lookup(config, ("imageReference",))
)
workdir = ""
mount_mode = "unknown"
for mount in mounts:
    target = mount.get("destination") or mount.get("dst") or mount.get("target") or ""
    if target != "/workdir":
        continue
    workdir = mount.get("source") or mount.get("src") or ""
    opts = mount.get("options") or []
    if isinstance(opts, str):
        opts = [opts]
    mount_mode = "ro" if "ro" in opts or "readonly" in opts else "rw"
    break

cpus = (
    lookup(config, ("cpus",))
    or lookup(config, ("resources", "cpus"))
    or lookup(data, ("cpus",))
    or lookup(data, ("resources", "cpus"))
)
memory = (
    lookup(config, ("memory",))
    or lookup(config, ("resources", "memory"))
    or lookup(data, ("memory",))
    or lookup(data, ("resources", "memory"))
)

print(f"{image}\t{workdir}\t{mount_mode}\t{cpus}\t{memory}")
PY
)"
  python_exec "$script" || echo -e "\t\t\t\t"
}

validate_mount_mode() {
  local name="$1"
  local read_only="$2"
  local mode
  mode="$("$CONTAINER_CMD" inspect "$name" 2>/dev/null | container_mount_mode)"
  if [ "$read_only" -eq 1 ]; then
    if [ "$mode" = "rw" ]; then
      die "Container already exists: $name (created with writable mount; remove it to recreate read-only, or run without --read-only)"
    fi
    if [ "$mode" = "unknown" ]; then
      warn "Unable to verify mount mode for $name; proceeding"
    fi
  else
    if [ "$mode" = "ro" ]; then
      die "Container already exists: $name (created with read-only mount; remove it to recreate writable, or use --read-only)"
    fi
    if [ "$mode" = "unknown" ]; then
      warn "Unable to verify mount mode for $name; proceeding"
    fi
  fi
}

image_list() {
  "$CONTAINER_CMD" image ls 2>/dev/null || "$CONTAINER_CMD" images 2>/dev/null || true
}

image_exists() {
  local image="$1"
  "$CONTAINER_CMD" image inspect "$image" >/dev/null 2>&1 && return 0
  parse_image_list | grep -Fqx -- "$image"
}

is_codex_image_family() {
  case "$1" in
    codex) return 0 ;;
    codex-*)
      if is_codex_backup_image_ref "$1"; then
        return 1
      fi
      return 0
      ;;
    *) return 1 ;;
  esac
}

is_codex_image_filter_name() {
  local image_filter_name="$1"
  if is_codex_image_family "$image_filter_name"; then
    return 0
  fi
  if [[ "$image_filter_name" == codex-* ]]; then
    return 0
  fi
  return 1
}

is_codex_backup_image_ref() {
  [[ "$1" =~ ^codex-.*-backup-[0-9]{14}$ ]]
}

codex_backup_base() {
  local image_ref="$1"
  if [[ "$image_ref" =~ ^(.*)-backup-[0-9]{14}$ ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

image_ref_matches_filter() {
  local image_ref="$1"
  local image_filter="$2"
  local family
  local backup_base

  if [ -z "$image_filter" ]; then
    return 0
  fi

  family="${image_ref%%:*}"
  if is_codex_image_family "$family"; then
    [ "$family" = "$image_filter" ]
    return
  fi
  if ! is_codex_backup_image_ref "$family"; then
    return 1
  fi
  if [ "$family" = "$image_filter" ]; then
    return 0
  fi
  backup_base="$(codex_backup_base "$family")"
  if [ "$backup_base" = "$image_filter" ]; then
    return 0
  fi
  return 1
}

image_prune_group() {
  local image_ref="$1"
  local family
  family="${image_ref%%:*}"
  if is_codex_backup_image_ref "$family"; then
    if [[ "$family" =~ ^(.*-backup)-[0-9]{14}$ ]]; then
      echo "${BASH_REMATCH[1]}"
    else
      echo "$family"
    fi
    return
  fi
  echo "$family"
}

is_codex_image_ref() {
  local image_ref="$1"
  local family
  local tag=""

  family="$image_ref"
  if [[ "$image_ref" == *:* ]]; then
    family="${image_ref%%:*}"
    tag="${image_ref#*:}"
  fi
  if [ -z "$tag" ] || [ "$tag" = "latest" ]; then
    if is_codex_image_family "$family"; then
      return 0
    fi
    if is_codex_backup_image_ref "$family"; then
      return 0
    fi
    return 1
  fi
  is_codex_image_family "$family" || return 1
  [ -n "$(timestamp_for_image_ref "$image_ref")" ]
}

parse_image_list() {
  image_list | awk '
    NR == 1 { next }
    NF >= 2 {
      repo = $1
      tag = $2
      if (repo == "" || repo == "<none>" || tag == "" || tag == "<none>") {
        next
      }
      if (tag == "latest") {
        print repo
      } else {
        print repo ":" tag
      }
    }
  '
}

list_codex_image_families_from_refs() {
  local refs="$1"
  printf '%s\n' "$refs" | while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if is_codex_image_family "${ref%%:*}"; then
      echo "${ref%%:*}"
    fi
  done | sort -u
}

timestamp_for_image_ref() {
  local image_ref="$1"
  if [[ "$image_ref" =~ ^[^:]+:([0-9]{8}-[0-9]{6})$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi
  if [[ "$image_ref" =~ ^(.*)-backup-([0-9]{8})([0-9]{6})$ ]]; then
    echo "${BASH_REMATCH[2]}-${BASH_REMATCH[3]}"
  fi
}

default_name() {
  local prefix="$1"
  local path="${2:-$PWD}"
  echo "${prefix}$(sanitize_container_name "$(basename "$path")")"
}

sanitize_container_name() {
  local raw="$1"
  local sanitized
  sanitized="$(printf '%s' "$raw" | tr -cs 'A-Za-z0-9_.-' '-')"
  sanitized="${sanitized#-}"
  sanitized="${sanitized%-}"
  if [ -z "$sanitized" ]; then
    sanitized="workdir"
  fi
  echo "$sanitized"
}

sanitize_image_name() {
  local raw="$1"
  local sanitized
  sanitized="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9._/-' '-')"
  sanitized="${sanitized#-}"
  sanitized="${sanitized%-}"
  if [ -z "$sanitized" ]; then
    sanitized="codex-backup"
  fi
  echo "$sanitized"
}

usage() {
  cat <<'EOF'
Usage: codexctl <command> [options]

Commands:
  build      Build Codex images
  run        Create/start a container for the current directory
  upgrade    Recreate a container from the latest image while preserving config
  auth       Run OpenAI device auth flow and store in Keychain
  exec       Exec into a running container (default: bash)
  su-exec    Exec into a running container as root (default: bash)
  start      Start a container
  stop       Stop a running container
  restart    Restart a container
  rm         Remove a container
  ls         List containers
  images     List local Codex images or prune old timestamp tags

Run "codexctl <command> --help" for command-specific options.
EOF
}

usage_build() {
  cat <<'EOF'
Usage: codexctl build [--image NAME] [--rebuild] [--snapshot] [--pull-base] [--refresh-base]

Options:
  --image NAME  Local image name to build (for example: codex, codex-python, codex-my-team)
  --rebuild     Rebuild images even if they already exist (disables build cache only; does not refresh FROM tags)
  --snapshot    Add a fresh UTC timestamp tag for existing images without rebuilding
  --pull-base     Pull the base image before building (preferred way to refresh remote FROM tags)
  --refresh-base  Remove the base image first so it is re-fetched

Each successful build keeps the stable image name (for example `codex`) and
also adds an immutable UTC timestamp tag (for example `codex:20260313-154500`).
Local image names follow this convention:
  codex         -> DockerFile
  codex-<name>  -> DockerFile.<name>

When a local Dockerfile uses FROM another local codex image, codexctl builds the
dependency chain first.
EOF
}

usage_run() {
  cat <<'EOF'
Usage: codexctl run [options]

Options:
  --name NAME     Container name (default: codex-<dir>)
  --image NAME    Image to use (default: codex)
  --workdir PATH  Host directory to mount at /workdir (default: cwd)
  --openai        Use OpenAI mode (device auth)
  --auth          Force OpenAI login flow
  --reset-config  Replace ~/.codex/config.toml and local_models.json from the image and recreate ~/.codex/AGENTS.md as a symlink
  --update        Update @openai/codex in the target container before launch
  --temp          Create a throwaway container (auto-removed after exit)
  --read-only     Mount workdir as read-only (requires new container)
  --shell         Start a shell (default shell) instead of default CMD
  --cmd ...       Run a custom command (must be last; cannot combine with --shell)
  --cpu NUM       CPU cores for container
  --mem SIZE      Memory limit (e.g. 8G)
EOF
}

usage_upgrade() {
  cat <<'EOF'
Usage: codexctl upgrade [options]

Options:
  --name NAME         Container name (default: codex-<dir>)
  --image NAME        Image to use for recreation (default: existing container image)
  --backup-image NAME Backup image name for container export (default: <name>-backup-<timestamp>)
  --no-backup         Skip container export backup image creation
  --overwrite-config  Replace ~/.codex/config.toml and local_models.json from the upgraded image and recreate ~/.codex/AGENTS.md as a symlink
EOF
}

usage_auth() {
  cat <<'EOF'
Usage: codexctl auth [options]

Options:
  --name NAME   Auth container name (default: codex-openai-auth-<dir>)
  --image NAME  Image to use (default: codex)
EOF
}

usage_exec() {
  cat <<'EOF'
Usage: codexctl exec [options] [command...]

Options:
  --name NAME  Container name (default: codex-<dir>)

If no command is provided, exec runs the default shell.
EOF
}

usage_su_exec() {
  cat <<'EOF'
Usage: codexctl su-exec [options] [command...]

Options:
  --name NAME  Container name (default: codex-<dir>)

If no command is provided, su-exec runs the default shell as root.
EOF
}

usage_simple_name() {
  cat <<'EOF'
Usage: codexctl <start|stop|restart|rm> [--name NAME]
EOF
}

usage_images() {
  cat <<'EOF'
Usage: codexctl images [options]
       codexctl images prune [options]
       codexctl images rm [options]

Commands:
  prune        Remove old timestamp-tagged Codex images
  rm           Remove all refs for one Codex image family or backup image

Options for `images`:
  --image NAME  Codex image family, custom codex-* image, or a backup base/image
  --backup      Show only backup image refs
  --all         Include non-Codex images
  --latest      Show only stable tags and newest timestamp tag per family

Options for `images prune`:
  --keep N      Keep the newest N timestamp tags per family (default: 1)
  --image NAME  Limit pruning to one image family, backup base, or exact backup image ref
  --backup      Prune only backup image refs
  --dry-run     Print images that would be deleted

Options for `images rm`:
  --image NAME  Remove one image family, custom codex-* image, or backup base/image
  --backup      Remove only backup image refs
  --dry-run     Print images that would be deleted
EOF
}

