  cat <<'EOF'
Usage: codexctl images prune [options]

Options:
  --keep N      Keep the newest N timestamp tags per family (default: 1)
  --image NAME  Limit pruning to one image family, backup base, or exact backup image ref
  --backup      Prune only backup image refs
  --dry-run     Print images that would be deleted
EOF
}

usage_images_rm() {
  cat <<'EOF'
Usage: codexctl images rm [options]

Options:
  --image NAME  Remove one image family, custom codex-* image, or backup base/image
  --backup      Remove only backup image refs
  --dry-run     Print images that would be deleted
EOF
}

images_print_latest() {
  local refs="$1"
  local image_filter="$2"
  local backup_only="$3"
  local family
  local family_refs
  local newest
  local backup_bases
  local backup_base
  local backup_family_refs

  if [ "$backup_only" -eq 1 ]; then
    backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
      if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
        continue
      fi
      if [ -n "$image_filter" ] && ! image_ref_matches_filter "$family_ref" "$image_filter"; then
        continue
      fi
      image_prune_group "$family_ref"
    done | sort -u)"
    [ -z "$backup_bases" ] && return 0

    while IFS= read -r backup_base; do
      [ -z "$backup_base" ] && continue
      backup_family_refs="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
        if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
          continue
        fi
        if [ "$backup_base" != "$(image_prune_group "$family_ref")" ]; then
          continue
        fi
        echo "$family_ref"
      done | sort -r || true)"
      if [ -n "$backup_family_refs" ]; then
        printf '%s\n' "$backup_family_refs"
      fi
    done <<< "$backup_bases"
    return 0
  fi

  while IFS= read -r family; do
    [ -z "$family" ] && continue
    if [ -n "$image_filter" ] && ! image_ref_matches_filter "$family" "$image_filter"; then
      continue
    fi
    family_refs="$(printf '%s\n' "$refs" | awk -F: -v family="$family" '$1 == family { print }' || true)"
    [ -z "$family_refs" ] && continue
    if printf '%s\n' "$family_refs" | grep -qx "$family"; then
      echo "$family"
    fi
    newest="$(printf '%s\n' "$family_refs" | grep -E "^${family}:[0-9]{8}-[0-9]{6}$" | sort -r | head -n 1 || true)"
    if [ -n "$newest" ]; then
      echo "$newest"
    fi
  done <<< "$(list_codex_image_families_from_refs "$refs")"

  backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
    if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
      continue
    fi
    if [ -n "$image_filter" ] && ! image_ref_matches_filter "$family_ref" "$image_filter"; then
      continue
    fi
    image_prune_group "$family_ref"
  done | sort -u)"
  [ -z "$backup_bases" ] && return 0

  while IFS= read -r backup_base; do
    [ -z "$backup_base" ] && continue
    backup_family_refs="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
      if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
        continue
      fi
      if [ "$backup_base" != "$(image_prune_group "$family_ref")" ]; then
        continue
      fi
      echo "$family_ref"
    done || true)"
    if [ -z "$backup_family_refs" ]; then
      continue
    fi
    newest="$(printf '%s\n' "$backup_family_refs" | sort -r | head -n 1 || true)"
    if [ -n "$newest" ]; then
      echo "$newest"
    fi
  done <<< "$backup_bases"
}

images_print_sorted() {
  local refs="$1"
  local include_all="$2"
  local image_filter="$3"
  local backup_only="$4"
  local family
  local family_refs
  local non_family_refs
  local backup_bases
  local backup_refs
  local backup_base
  local backup_ref

  if [ "$backup_only" -eq 1 ]; then
    backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
      if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
        continue
      fi
      if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
        continue
      fi
      image_prune_group "$backup_ref"
    done | sort -u || true)"
    if [ -n "$backup_bases" ]; then
      while IFS= read -r backup_base; do
        [ -z "$backup_base" ] && continue
        backup_refs="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
          if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
            continue
          fi
          if [ "$backup_base" != "$(image_prune_group "$backup_ref")" ]; then
            continue
          fi
          if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
            continue
          fi
          echo "$backup_ref"
        done | sort -r || true)"
        if [ -n "$backup_refs" ]; then
          printf '%s\n' "$backup_refs"
        fi
      done <<< "$backup_bases"
    fi
    return 0
  fi

  while IFS= read -r family; do
    [ -z "$family" ] && continue
    family_refs="$(printf '%s\n' "$refs" | awk -F: -v family="$family" '$1 == family { print }' || true)"
    if [ -n "$image_filter" ]; then
      family_refs="$(printf '%s\n' "$family_refs" | while IFS= read -r family_ref; do
        if image_ref_matches_filter "$family_ref" "$image_filter"; then
          echo "$family_ref"
        fi
      done || true)"
    fi
    [ -z "$family_refs" ] && continue
    if printf '%s\n' "$family_refs" | grep -qx "$family"; then
      echo "$family"
    fi
    printf '%s\n' "$family_refs" | awk -F: '$2 ~ /^[0-9]{8}-[0-9]{6}$/ { print }' | sort -r
    printf '%s\n' "$family_refs" | awk -F: '$2 != "" && $2 !~ /^[0-9]{8}-[0-9]{6}$/ { print }'
  done <<< "$(list_codex_image_families_from_refs "$refs")"

  if [ "$include_all" -eq 1 ] && [ -z "$image_filter" ]; then
    non_family_refs="$(printf '%s\n' "$refs" | while IFS= read -r ref; do
      [ -z "$ref" ] && continue
      if ! is_codex_image_ref "$ref"; then
        echo "$ref"
      fi
    done || true)"
    if [ -n "$non_family_refs" ]; then
      printf '%s\n' "$non_family_refs"
    fi
  fi

  backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
    if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
      continue
    fi
    if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
      continue
    fi
    image_prune_group "$backup_ref"
  done | sort -u || true)"
  if [ -n "$backup_bases" ]; then
    while IFS= read -r backup_base; do
      [ -z "$backup_base" ] && continue
      backup_refs="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
        if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
          continue
        fi
        if [ "$backup_base" != "$(image_prune_group "$backup_ref")" ]; then
          continue
        fi
        if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
          continue
        fi
        echo "$backup_ref"
      done | sort -r || true)"
      if [ -n "$backup_refs" ]; then
        printf '%s\n' "$backup_refs"
      fi
    done <<< "$backup_bases"
  fi
}

remove_image_ref() {
  local image_ref="$1"
  if "$CONTAINER_CMD" image rm "$image_ref" >/dev/null 2>&1; then
    return 0
  fi
  if "$CONTAINER_CMD" image delete "$image_ref" >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

images_list_cmd() {
  local image=""
  local backup=0
  local include_all=0
  local latest=0
  local refs=""
  local filtered_refs=""
  local ref

  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --backup) backup=1; shift ;;
      --all) include_all=1; shift ;;
      --latest) latest=1; shift ;;
      --help) usage_images; return 0 ;;
      *) die "Unknown option for images: $1" ;;
    esac
  done
  if [ -n "$image" ] && ! is_codex_image_filter_name "$image"; then
    die "Unknown image: $image"
  fi
  if [ "$include_all" -eq 1 ] && [ "$latest" -eq 1 ]; then
    die "Cannot combine --all with --latest"
  fi
  require_container

  refs="$(parse_image_list || true)"
  while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if [ "$include_all" -eq 0 ] && ! is_codex_image_ref "$ref"; then
      continue
    fi
    if [ -n "$image" ] && ! image_ref_matches_filter "$ref" "$image"; then
      continue
    fi
    if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "$ref"; then
      continue
    fi
    filtered_refs="${filtered_refs}${ref}"$'\n'
  done <<< "$refs"
  filtered_refs="${filtered_refs%$'\n'}"
  [ -z "$filtered_refs" ] && return 0

  if [ "$latest" -eq 1 ]; then
    images_print_latest "$filtered_refs" "$image" "$backup"
    return 0
  fi
  images_print_sorted "$filtered_refs" "$include_all" "$image" "$backup"
}

images_prune_cmd() {
  local image=""
  local keep=1
  local backup=0
  local dry_run=0
  local refs=""
  local family_refs=""
  local to_remove=""
  local kept=0
  local failures=0
  local ref=""
  local family=""
  local deletion_ref=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --keep) keep="$2"; shift 2 ;;
      --backup) backup=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      --help) usage_images_prune; return 0 ;;
      *) die "Unknown option for images prune: $1" ;;
    esac
  done
  if ! [[ "$keep" =~ ^[0-9]+$ ]]; then
    die "--keep must be a non-negative integer: $keep"
  fi
  if [ -n "$image" ] && ! is_codex_image_filter_name "$image"; then
    die "Unknown image: $image"
  fi
  require_container

  refs="$(parse_image_list || true)"
  for family in $(printf '%s\n' "$refs" | while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if [ -z "$(timestamp_for_image_ref "$ref")" ]; then
      continue
    fi
    if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "$ref"; then
      continue
    fi
    if [ -n "$image" ] && ! image_ref_matches_filter "$ref" "$image"; then
      continue
    fi
    image_prune_group "$ref"
  done | sort -u || true); do
    [ -z "$family" ] && continue
    family_refs=""
    while IFS= read -r ref; do
      [ -z "$ref" ] && continue
      if [ "$(image_prune_group "$ref")" != "$family" ]; then
        continue
      fi
      if [ -z "$(timestamp_for_image_ref "$ref")" ]; then
        continue
      fi
      if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "$ref"; then
        continue
      fi
      if [ -n "$image" ] && ! image_ref_matches_filter "$ref" "$image"; then
        continue
      fi
      family_refs="${family_refs}${ref}"$'\n'
    done <<< "$refs"
    family_refs="${family_refs%$'\n'}"
    [ -z "$family_refs" ] && continue
    kept=0
    while IFS= read -r ref; do
      if [ "$kept" -lt "$keep" ]; then
        kept=$((kept + 1))
        continue
      fi
      to_remove="${to_remove}${ref}"$'\n'
    done <<< "$(printf '%s\n' "$family_refs" | sort -r || true)"
  done

  to_remove="${to_remove%$'\n'}"
  [ -z "$to_remove" ] && echo "No images to prune" && return 0

  while IFS= read -r deletion_ref; do
    [ -z "$deletion_ref" ] && continue
    if [ "$dry_run" -eq 1 ]; then
      echo "Would remove image: $deletion_ref"
      continue
    fi
    if remove_image_ref "$deletion_ref"; then
      echo "Removed image: $deletion_ref"
    else
      echo "Failed to remove image: $deletion_ref" >&2
      failures=$((failures + 1))
    fi
  done <<< "$to_remove"

  if [ "$failures" -ne 0 ]; then
    return 1
  fi

  return 0
}

images_rm_cmd() {
  local image=""
  local backup=0
  local dry_run=0
  local refs=""
  local to_remove=""
  local failures=0
  local ref=""
  local deletion_ref=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --backup) backup=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      --help) usage_images_rm; return 0 ;;
      *) die "Unknown option for images rm: $1" ;;
    esac
  done
  [ -n "$image" ] || die "--image is required for images rm"
  if ! is_codex_image_filter_name "$image"; then
    die "Unknown image: $image"
  fi
  require_container

  refs="$(parse_image_list || true)"
  while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if ! image_ref_matches_filter "$ref" "$image"; then
      continue
    fi
    if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "${ref%%:*}"; then
      continue
    fi
    to_remove="${to_remove}${ref}"$'\n'
  done <<< "$refs"

  to_remove="${to_remove%$'\n'}"
  [ -z "$to_remove" ] && echo "No images to remove" && return 0

  while IFS= read -r deletion_ref; do
    [ -z "$deletion_ref" ] && continue
    if [ "$dry_run" -eq 1 ]; then
      echo "Would remove image: $deletion_ref"
      continue
    fi
    if remove_image_ref "$deletion_ref"; then
      echo "Removed image: $deletion_ref"
    else
      echo "Failed to remove image: $deletion_ref" >&2
      failures=$((failures + 1))
    fi
  done <<< "$(printf '%s\n' "$to_remove" | sort -r || true)"

  if [ "$failures" -ne 0 ]; then
    return 1
  fi

  return 0
}

images_cmd() {
  if [ "$#" -gt 0 ] && [ "${1:0:2}" != "--" ]; then
    case "$1" in
      prune) shift; images_prune_cmd "$@" ;;
      rm) shift; images_rm_cmd "$@" ;;
      --help|-h) usage_images; return 0 ;;
      *) die "Unknown images subcommand: $1" ;;
    esac
  else
    images_list_cmd "$@"
  fi
}

build_cmd() {
  local image=""
  local rebuild=0
  local snapshot=0
  local refresh_base=0
  local pull_base=0
  local no_cache=""
  local build_stamp
  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --rebuild) rebuild=1; shift ;;
      --snapshot) snapshot=1; shift ;;
      --refresh-base) refresh_base=1; shift ;;
      --pull-base) pull_base=1; shift ;;
      --help) usage_build; return 0 ;;
      *) echo "Error: Unknown option for build: $1" >&2; usage_build; return 1 ;;
    esac
  done

  require_container
  if [ "$rebuild" -eq 1 ]; then
    no_cache="--no-cache"
  fi
  build_stamp="$(date -u +%Y%m%d-%H%M%S)"

  remove_image() {
    local name="$1"
    if "$CONTAINER_CMD" image rm "$name" >/dev/null 2>&1; then
      echo "Removed base image: $name"
      return 0
    fi
    if "$CONTAINER_CMD" image delete "$name" >/dev/null 2>&1; then
      echo "Removed base image: $name"
      return 0
    fi
    echo "Base image not removed (may not exist or command unsupported): $name" >&2
  }

  is_local_codex_build_image() {
    case "$1" in
      codex|codex-*) return 0 ;;
      *) return 1 ;;
    esac
  }

  dockerfile_name_for_image() {
    local name="$1"
    case "$name" in
      codex) echo "DockerFile" ;;
      codex-*) echo "DockerFile.${name#codex-}" ;;
      *) return 1 ;;
    esac
  }

  dockerfile_path_for_image() {
    local name="$1"
    local file
    file="$(dockerfile_name_for_image "$name")" || return 1
    echo "$SCRIPT_DIR/$file"
  }

  local_image_for_dockerfile_name() {
    local file_name="$1"
    case "$file_name" in
      DockerFile) echo "codex" ;;
      DockerFile.*) echo "codex-${file_name#DockerFile.}" ;;
      *) return 1 ;;
    esac
  }

  local_dockerfile_exists_for_image() {
    local image_name="$1"
    local file_path
    if ! file_path="$(dockerfile_path_for_image "$image_name")"; then
      return 1
    fi
    [ -f "$file_path" ]
  }

  list_local_build_images() {
    local file_path
    local file_name
    local image_name

    for file_path in "$SCRIPT_DIR"/DockerFile*; do
      [ -e "$file_path" ] || continue
      [ -f "$file_path" ] || continue
      file_name="$(basename "$file_path")"
      case "$file_name" in
        DockerFile|DockerFile.*)
          image_name="$(local_image_for_dockerfile_name "$file_name" || true)"
          [ -n "$image_name" ] && printf '%s\n' "$image_name"
          ;;
      esac
    done | sort -u
  }

  base_image_from_file() {
    awk '
      toupper($1) == "FROM" {
        for (i = 2; i <= NF; i++) {
          if ($i ~ /^--/) {
            continue
          }
          print $i
          exit
        }
      }
    ' "$1"
  }

  refresh_base_image() {
    local file="$1"
    local base
    base="$(base_image_from_file "$file")"
    if [ -n "$base" ]; then
      if local_dockerfile_exists_for_image "$base"; then
        echo "Skipping base image removal for local image: $base"
        return 0
      fi
      remove_image "$base"
    fi
  }

  pull_base_image() {
    local file="$1"
    local base
    base="$(base_image_from_file "$file")"
    if [ -n "$base" ]; then
      if local_dockerfile_exists_for_image "$base"; then
        echo "Skipping base image pull for local image: $base"
        return 0
      fi
      "$CONTAINER_CMD" image pull "$base"
    fi
  }

  local build_order_lines=""
  local build_seen_lines=""
  local build_visiting_lines=""

  list_has_line() {
    local lines="$1"
    local value="$2"
    [ -n "$value" ] || return 1
    printf '%s\n' "$lines" | grep -Fqx -- "$value"
  }

  resolve_build_dependencies() {
    local name="$1"
    local file_path
    local file_name
    local base
    local base_file

    if list_has_line "$build_seen_lines" "$name"; then
      return 0
    fi
    if list_has_line "$build_visiting_lines" "$name"; then
      die "Cyclic local image dependency detected while resolving $name"
    fi
    if ! is_local_codex_build_image "$name"; then
      die "Unknown image: $name"
    fi

    file_path="$(dockerfile_path_for_image "$name" || true)"
    if [ -z "$file_path" ] || [ ! -f "$file_path" ]; then
      file_name="$(dockerfile_name_for_image "$name" || true)"
      if [ -n "$file_name" ]; then
        die "Unknown image: $name (expected local Dockerfile: $file_name)"
      fi
      die "Unknown image: $name"
    fi

    build_visiting_lines="${build_visiting_lines}${name}"$'\n'
    base="$(base_image_from_file "$file_path")"
    if [ -n "$base" ] && is_local_codex_build_image "$base"; then
      if ! local_dockerfile_exists_for_image "$base"; then
        base_file="$(dockerfile_name_for_image "$base" || true)"
        die "Missing local base image definition for $name: expected $base_file because $file_path uses FROM $base"
      fi
      resolve_build_dependencies "$base"
    fi
    build_visiting_lines="$(printf '%s\n' "$build_visiting_lines" | grep -Fvx -- "$name" || true)"
    build_seen_lines="${build_seen_lines}${name}"$'\n'
    build_order_lines="${build_order_lines}${name}"$'\n'
  }

  build_one() {
    local name="$1"
    local file
    local file_path
    local context="$SCRIPT_DIR"
    local versioned_name="${name}:${build_stamp}"
    local base=""
    file="$(dockerfile_name_for_image "$name")"
    file_path="$SCRIPT_DIR/$file"
    if [ "$rebuild" -eq 0 ] && image_exists "$name"; then
      if [ "$snapshot" -eq 1 ]; then
        echo "Snapshotting existing image tags: $name, $versioned_name"
        "$CONTAINER_CMD" image tag "$name" "$versioned_name"
        return 0
      fi
      echo "Image already exists: $name (use --rebuild to rebuild)"
      return 0
    fi
    if [ "$refresh_base" -eq 1 ]; then
      refresh_base_image "$file_path"
    fi
    if [ "$pull_base" -eq 1 ]; then
      pull_base_image "$file_path"
    fi
    if [ "$rebuild" -eq 1 ] && [ "$pull_base" -eq 0 ] && [ "$refresh_base" -eq 0 ]; then
      base="$(base_image_from_file "$file_path")"
      if [ -n "$base" ] && ! local_dockerfile_exists_for_image "$base"; then
        echo "Note: --rebuild disables layer cache but does not refresh remote base image tags."
        echo "      Use --pull-base (preferred) or --refresh-base to update $base."
      fi
    fi
    echo "Building image tags: $name, $versioned_name"
    if [ -n "$no_cache" ]; then
      "$CONTAINER_CMD" build -t "$name" -f "$file_path" "$no_cache" "$context"
    else
      "$CONTAINER_CMD" build -t "$name" -f "$file_path" "$context"
    fi
    "$CONTAINER_CMD" image tag "$name" "$versioned_name"
  }

  if [ -n "$image" ]; then
    resolve_build_dependencies "$image"
  else
    while IFS= read -r local_image; do
      [ -z "$local_image" ] && continue
      resolve_build_dependencies "$local_image"
    done <<< "$(list_local_build_images)"
  fi

  if [ -z "$build_order_lines" ]; then
    die "No local DockerFiles found for build"
  fi

  while IFS= read -r build_image; do
    [ -z "$build_image" ] && continue
    build_one "$build_image"
  done <<< "$build_order_lines"
}

run_auth_flow() {
  local image="$1"
  local auth_name="$2"
  local created=0

  cleanup_auth_container() {
    if [ "$created" -eq 1 ] && container_exists "$auth_name"; then
      "$CONTAINER_CMD" stop "$auth_name" >/dev/null 2>&1 || true
      "$CONTAINER_CMD" rm "$auth_name" >/dev/null 2>&1 || true
    fi
  }

  trap cleanup_auth_container EXIT

  [ -x "$KEYCHAIN_SCRIPT" ] || die "Missing $KEYCHAIN_SCRIPT"

  if container_exists "$auth_name"; then
    die "Auth container already exists: $auth_name (remove it and retry)"
  fi

  "$CONTAINER_CMD" create -t \
    --name "$auth_name" \
    "$image" sh -c 'sleep infinity'
  created=1

  "$CONTAINER_CMD" start "$auth_name"
  "$CONTAINER_CMD" exec -it "$auth_name" bash -lc 'codex login --device-auth'
  "$KEYCHAIN_SCRIPT" store-from-container "$auth_name"
  "$CONTAINER_CMD" stop "$auth_name"
  "$CONTAINER_CMD" rm "$auth_name"
  created=0
  trap - EXIT
}

backup_codex_config() {
  local name="$1"
  local backup_file="$2"
  if ! "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" test -d /home/coder/.codex; then
    return 0
  fi
  "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" sh -lc 'cd /home/coder && tar -cf - .codex' >"$backup_file"
}

restore_codex_config() {
  local name="$1"
  local backup_file="$2"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'mkdir -p /home/coder && chown coder:coder /home/coder'
  if [ ! -s "$backup_file" ]; then
    "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'mkdir -p /home/coder/.codex && chown -R coder:coder /home/coder/.codex'
    return 0
  fi
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'rm -rf /home/coder/.codex && mkdir -p /home/coder'
  "$CONTAINER_CMD" exec -i -u 0 "$name" sh -lc 'cd /home/coder && tar -xf -' <"$backup_file"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'chown -R coder:coder /home/coder/.codex'
}

codex_agents_state() {
  local name="$1"
  if "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" test -L /home/coder/.codex/AGENTS.md; then
    echo "symlink"
    return 0
  fi
  if "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" test -f /home/coder/.codex/AGENTS.md; then
    echo "file"
    return 0
  fi
  if "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" test -e /home/coder/.codex/AGENTS.md; then
    echo "other"
    return 0
  fi
  echo "missing"
}

overwrite_codex_config() {
  local name="$1"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'mkdir -p /home/coder/.codex'
  if ! "$CONTAINER_CMD" exec "$name" sh -lc 'test -f /etc/codexctl/config.toml'; then
    die "Image does not include /etc/codexctl/config.toml for overwrite in $name"
  fi
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'cp /etc/codexctl/config.toml /home/coder/.codex/config.toml'
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'if test -f /etc/codexctl/local_models.json; then cp /etc/codexctl/local_models.json /home/coder/.codex/local_models.json; else rm -f /home/coder/.codex/local_models.json; fi'
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'ln -sf /etc/codexctl/image.md /home/coder/.codex/AGENTS.md && chown -h coder:coder /home/coder/.codex/AGENTS.md && chown coder:coder /home/coder/.codex/config.toml && if test -f /home/coder/.codex/local_models.json; then chown coder:coder /home/coder/.codex/local_models.json; fi'
}

ensure_keychain() {
  [ -x "$KEYCHAIN_SCRIPT" ] || die "Missing $KEYCHAIN_SCRIPT"
  "$KEYCHAIN_SCRIPT" verify >/dev/null 2>&1
}

auth_info_from_json() {
  local script
  script="$(cat <<'PY'
import json
import re
import sys

raw = sys.stdin.buffer.read()

def extract_from_json(payload):
    token = payload.get("refresh_token", "")
    if not token:
        tokens = payload.get("tokens", {})
        if isinstance(tokens, dict):
            token = tokens.get("refresh_token", "")
    last_refresh = payload.get("last_refresh", "")
    return token, last_refresh

try:
    data = json.loads(raw.decode("utf-8"))
    token, last_refresh = extract_from_json(data)
    print(f"{token}\t{last_refresh}")
except Exception:
    text = raw.decode("utf-8", "ignore")
    token_match = re.search(r'"refresh_token"\s*:\s*"([^"]+)"', text)
    refresh_match = re.search(r'"last_refresh"\s*:\s*"([^"]+)"', text)
    token = token_match.group(1) if token_match else ""
    last_refresh = refresh_match.group(1) if refresh_match else ""
    print(f"{token}\t{last_refresh}")
PY
)"
  python_exec "$script"
}

keychain_auth_info() {
  "$KEYCHAIN_SCRIPT" read | auth_info_from_json
}

container_auth_info() {
  local name="$1"
  if ! "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" test -f /home/coder/.codex/auth.json; then
    echo -e "\t"
    return 0
  fi
  "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" cat /home/coder/.codex/auth.json | auth_info_from_json
}

sync_openai_auth_to_container() {
  local name="$1"
  if ! ensure_keychain; then
    die "Missing OpenAI auth in Keychain. Run: codexctl auth"
  fi
  local keychain_info
  local keychain_token
  local keychain_refresh
  keychain_info="$(keychain_auth_info)"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  if [ -z "$keychain_token" ]; then
    die "Keychain auth missing refresh_token. Run: codexctl auth"
  fi
  local container_info
  local container_token
  local container_refresh
  container_info="$(container_auth_info "$name")"
  IFS=$'\t' read -r container_token container_refresh <<<"$container_info"
  if [ -z "$container_token" ]; then
    echo "Refreshing OpenAI auth in $name" >&2
    "$KEYCHAIN_SCRIPT" load-to-container "$name"
    return 0
  fi
  if [ "$container_token" = "$keychain_token" ] && [ "$container_refresh" = "$keychain_refresh" ]; then
    return 0
  fi
  echo "Refreshing OpenAI auth in $name" >&2
  "$KEYCHAIN_SCRIPT" load-to-container "$name"
}

sync_openai_auth_from_container() {
  local name="$1"
  local container_info
  local container_token
  local container_refresh
  container_info="$(container_auth_info "$name")"
  IFS=$'\t' read -r container_token container_refresh <<<"$container_info"
  if [ -z "$container_token" ] || [ -z "$container_refresh" ]; then
    return 0
  fi
  if ! ensure_keychain; then
    echo "Keychain auth missing; skipping post-run sync from $name" >&2
    return 0
  fi
  local keychain_info
  local keychain_token
  local keychain_refresh
  keychain_info="$(keychain_auth_info)"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  if [ -z "$keychain_token" ]; then
    echo "Keychain auth missing refresh_token; skipping post-run sync from $name" >&2
    return 0
  fi
  if [ -z "$keychain_refresh" ] || [[ "$container_refresh" < "$keychain_refresh" ]] || [ "$container_refresh" = "$keychain_refresh" ]; then
    return 0
  fi
  echo "Updating Keychain auth from $name" >&2
  "$KEYCHAIN_SCRIPT" store-from-container "$name"
}

run_container() {
  local name="$1"
  local image="$2"
  local temp="$3"
  local shell="$4"
  local cpu="$5"
  local mem="$6"
  local read_only="$7"
  local workdir="$8"
  local pre_exec="$9"
  local post_exec="${10}"
  local reset_config="${11}"
  shift 11
  local cmd=("$@")
  local exit_code=0
  local started=0
  local already_running=0
  local actual_name="$name"

  # Execute command inside the container and preserve the exit code.
  run_exec() {
    if [ "$shell" -eq 1 ]; then
      if ! "$CONTAINER_CMD" exec -it "$actual_name" "${SETPRIV_ARGS[@]}" "$DEFAULT_SHELL" "-l"; then
        exit_code=$?
      fi
    else
      if ! "$CONTAINER_CMD" exec -it "$actual_name" "${SETPRIV_ARGS[@]}" "${cmd[@]}"; then
        exit_code=$?
      fi
    fi
  }

  # Lifecycle: create if missing, start if needed, pre_exec, exec, stop, remove if temp.
  if [ -n "$actual_name" ] && container_exists "$actual_name"; then
    validate_mount_mode "$actual_name" "$read_only"
  fi
  if [ -n "$actual_name" ] && container_running "$actual_name"; then
    already_running=1
  else
    if [ -n "$actual_name" ] && [ "$temp" -eq 1 ] && container_exists "$actual_name"; then
      die "Container already exists: $actual_name (omit --temp or remove it)"
    fi
    if [ "$temp" -eq 0 ] && [ -z "$actual_name" ]; then
      die "Missing container name"
    fi

    if [ -z "$actual_name" ] || ! container_exists "$actual_name"; then
      echo "Creating container..." >&2
      local create_cmd=("$CONTAINER_CMD" create -t)
      if [ -n "$cpu" ]; then
        create_cmd+=(-c "$cpu")
      fi
      if [ -n "$mem" ]; then
        create_cmd+=(-m "$mem")
      fi
      if [ -n "$actual_name" ]; then
        create_cmd+=(--name "$actual_name")
      fi
      local mount_opts="type=bind,src=$workdir,dst=/workdir"
      if [ "$read_only" -eq 1 ]; then
        mount_opts="${mount_opts},readonly"
      fi
      create_cmd+=(
        --mount "$mount_opts"
        "$image" sh -c 'sleep infinity'
      )
      if [ -z "$actual_name" ]; then
        actual_name="$("${create_cmd[@]}")"
        [ -n "$actual_name" ] || die "Failed to create temporary container"
      else
        "${create_cmd[@]}"
      fi
    fi

    echo "Starting container: $actual_name" >&2
    "$CONTAINER_CMD" start "$actual_name"
    started=1
  fi

  if [ "$reset_config" -eq 1 ]; then
    overwrite_codex_config "$actual_name"
  fi
  if [ -n "$pre_exec" ]; then
    "$pre_exec" "$actual_name"
  fi
  run_exec
  if [ -n "$post_exec" ]; then
    if ! "$post_exec" "$actual_name"; then
      warn "post-run step failed for $actual_name"
    fi
  fi
  if [ "$already_running" -eq 1 ]; then
    return "$exit_code"
  fi
  if [ "$started" -eq 1 ]; then
    echo "Stopping container: $actual_name" >&2
    "$CONTAINER_CMD" stop "$actual_name" >/dev/null 2>&1
  fi
  if [ "$temp" -eq 1 ]; then
    echo "Removing container: $actual_name" >&2
    "$CONTAINER_CMD" rm "$actual_name" >/dev/null 2>&1
  fi
  return "$exit_code"
}

run_mode() {
  local name="$1"
  local image="$2"
  local temp="$3"
  local shell="$4"
  local openai="$5"
  local auth="$6"
  local update="$7"
  local cpu="$8"
  local mem="$9"
  local read_only="${10}"
  local workdir="${11}"
  local reset_config="${12}"
  shift 12
  local -a cmd_override=("$@")
  local pre_exec=""
  local post_exec=""
  local cmd=("${DEFAULT_CODEX_CMD[@]}" --profile "$DEFAULT_CODEX_PROFILE" --cd /workdir)

  if [ "$openai" -eq 1 ]; then
    pre_exec="openai_pre_exec"
    post_exec="openai_post_exec"
    cmd=("${DEFAULT_CODEX_CMD[@]}" --cd /workdir)
    if [ "$auth" -eq 1 ] || ! ensure_keychain; then
      run_auth_flow "$image" "$(default_name "$AUTH_NAME_PREFIX")"
    fi
  else
    if [ "$shell" -eq 0 ] && [ "${#cmd_override[@]}" -eq 0 ]; then
      pre_exec="local_model_pre_exec"
    fi
  fi
  if [ "$update" -eq 1 ]; then
    case "$pre_exec" in
      openai_pre_exec) pre_exec="openai_update_pre_exec" ;;
      local_model_pre_exec) pre_exec="local_model_update_pre_exec" ;;
      *) pre_exec="update_codex_pre_exec" ;;
    esac
  fi

  if [ "${#cmd_override[@]}" -gt 0 ]; then
    cmd=("${cmd_override[@]}")
    shell=0
  fi

  run_container "$name" "$image" "$temp" "$shell" "$cpu" "$mem" "$read_only" "$workdir" "$pre_exec" "$post_exec" "$reset_config" "${cmd[@]}"
}

openai_pre_exec() {
  local name="$1"
  sync_openai_auth_to_container "$name"
