#!/usr/bin/env bash
set -euo pipefail

CONTAINER_CMD="${CONTAINER_CMD:-container}"
DEFAULT_IMAGE="agent-plain"
DEFAULT_NAME_PREFIX="agent-"
AUTH_NAME_PREFIX="agent-openai-auth-"
DEFAULT_SHELL="${CODEX_SHELL:-bash}"
DEFAULT_CODEX_PROFILE="${CODEX_PROFILE:-gpt-oss}"
DEFAULT_CODEX_CMD=(codex)
SETPRIV_ARGS=(setpriv --inh-caps=-all --ambient-caps=-all --bounding-set=-all --no-new-privs --)

resolve_script_path() {
  local path="$1"
  while [ -L "$path" ]; do
    local target
    target="$(readlink "$path")"
    if [[ "$target" != /* ]]; then
      path="$(CDPATH= cd -- "$(dirname -- "$path")" && pwd)/$target"
    else
      path="$target"
    fi
  done
  echo "$path"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
CLI_NAME="${AGENTCTL_NAME:-$(basename -- "$SCRIPT_PATH")}"
KEYCHAIN_SCRIPT="$SCRIPT_DIR/codex-auth-keychain.sh"
OPENAI_RUNTIME_ID="codex"
OPENAI_AUTH_FORMAT="json_refresh_token"

die() {
  echo "Error: $*" >&2
  exit 1
}

warn() {
  echo "Warning: $*" >&2
}

require_container() {
  command -v "$CONTAINER_CMD" >/dev/null 2>&1 || die "Missing '$CONTAINER_CMD' command"
}

require_container_backup_support() {
  if ! "$CONTAINER_CMD" export --help 2>/dev/null | grep -Fq -- '--output'; then
    die "Upgrade backups require a container runtime with 'container export --output <path>' support"
  fi
}

python_exec() {
  local python_cmd=""
  local script="$1"
  shift
  if command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
  elif command -v python >/dev/null 2>&1; then
    python_cmd="python"
  else
    die "Missing python (python3 or python)"
  fi
  "$python_cmd" -c "$script" "$@"
}

container_list_all() {
  "$CONTAINER_CMD" ls -a 2>/dev/null || true
}

container_list_running() {
  "$CONTAINER_CMD" ls 2>/dev/null || true
}

container_exists() {
  container_list_all | grep -q -E "(^|[[:space:]])$1([[:space:]]|$)"
}

container_running() {
  container_list_running | grep -q -E "(^|[[:space:]])$1([[:space:]]|$)"
}

stop_buildkit_container() {
  if container_exists buildkit; then
    "$CONTAINER_CMD" stop buildkit >/dev/null 2>&1 || true
  fi
}

cleanup_temp_dir() {
  local path="$1"

  [ -n "$path" ] || return 0
  [ -e "$path" ] || return 0

  # Exported container files can preserve restrictive modes that prevent
  # best-effort host cleanup on exit.
  chmod -R u+rwX "$path" >/dev/null 2>&1 || true
  rm -rf "$path" >/dev/null 2>&1 || true
}

build_backup_image_from_export() {
  local backup_image="$1"
  local container_name="$2"
  local export_file="$3"
  local backup_root="$4"
  local backup_dockerfile="$5"

  mkdir -p "$backup_root"
  tar -xf "$export_file" -C "$backup_root"
  cat >"$backup_dockerfile" <<EOF
FROM scratch
COPY . /
EOF
  "$CONTAINER_CMD" build -t "$backup_image" -f "$backup_dockerfile" "$backup_root"
}

container_mount_mode() {
  local script
  script="$(cat <<'PY'
import json
import sys

try:
    data = json.loads(sys.stdin.read())
except Exception:
    print("unknown")
    sys.exit(0)

if isinstance(data, list) and data:
    data = data[0]

config = data.get("configuration") or data
mounts = config.get("mounts") or []

mode = "unknown"
for mount in mounts:
    target = mount.get("destination") or mount.get("dst") or ""
    if target != "/workdir":
        continue
    opts = mount.get("options") or []
    if isinstance(opts, str):
        opts = [opts]
    mode = "ro" if "ro" in opts else "rw"
    break

print(mode)
PY
)"
  python_exec "$script" || echo "unknown"
}

container_upgrade_info() {
  local script
  script="$(cat <<'PY'
import json
import sys

def lookup(data, *paths):
    for path in paths:
        cur = data
        ok = True
        for part in path:
            if isinstance(cur, dict) and part in cur:
                cur = cur[part]
            else:
                ok = False
                break
        if ok and cur not in (None, ""):
            return cur
    return ""

def string_value(value):
    if isinstance(value, str):
        return value
    if isinstance(value, dict):
        for key in ("name", "reference", "image", "imageName", "id"):
            inner = value.get(key)
            if isinstance(inner, str) and inner:
                return inner
    return ""

try:
    data = json.loads(sys.stdin.read())
except Exception:
    print("\t\t\t\t")
    sys.exit(0)

if isinstance(data, list) and data:
    data = data[0]

config = data.get("configuration") or data
mounts = config.get("mounts") or []

image = string_value(
    lookup(data, ("image", "name"))
    or lookup(config, ("image", "name"))
    or lookup(data, ("image",))
    or lookup(config, ("image",))
    or lookup(data, ("imageReference",))
    or lookup(config, ("imageReference",))
)
workdir = ""
mount_mode = "unknown"
for mount in mounts:
    target = mount.get("destination") or mount.get("dst") or mount.get("target") or ""
    if target != "/workdir":
        continue
    workdir = mount.get("source") or mount.get("src") or ""
    opts = mount.get("options") or []
    if isinstance(opts, str):
        opts = [opts]
    mount_mode = "ro" if "ro" in opts or "readonly" in opts else "rw"
    break

cpus = (
    lookup(config, ("cpus",))
    or lookup(config, ("resources", "cpus"))
    or lookup(data, ("cpus",))
    or lookup(data, ("resources", "cpus"))
)
memory = (
    lookup(config, ("memory",))
    or lookup(config, ("resources", "memory"))
    or lookup(data, ("memory",))
    or lookup(data, ("resources", "memory"))
)

print(f"{image}\t{workdir}\t{mount_mode}\t{cpus}\t{memory}")
PY
)"
  python_exec "$script" || echo -e "\t\t\t\t"
}

validate_mount_mode() {
  local name="$1"
  local read_only="$2"
  local mode
  mode="$("$CONTAINER_CMD" inspect "$name" 2>/dev/null | container_mount_mode)"
  if [ "$read_only" -eq 1 ]; then
    if [ "$mode" = "rw" ]; then
      die "Container already exists: $name (created with writable mount; remove it to recreate read-only, or run without --read-only)"
    fi
    if [ "$mode" = "unknown" ]; then
      warn "Unable to verify mount mode for $name; proceeding"
    fi
  else
    if [ "$mode" = "ro" ]; then
      die "Container already exists: $name (created with read-only mount; remove it to recreate writable, or use --read-only)"
    fi
    if [ "$mode" = "unknown" ]; then
      warn "Unable to verify mount mode for $name; proceeding"
    fi
  fi
}

image_list() {
  "$CONTAINER_CMD" image ls 2>/dev/null || "$CONTAINER_CMD" images 2>/dev/null || true
}

image_exists() {
  local image="$1"
  "$CONTAINER_CMD" image inspect "$image" >/dev/null 2>&1 && return 0
  parse_image_list | grep -Fqx -- "$image"
}

image_family_preferred() {
  local image="$1"
  local family="${image%%:*}"
  local tag=""

  if [ "$family" != "$image" ]; then
    tag=":${image#*:}"
  fi

  case "$family" in
    codex|agent) echo "agent-plain${tag}" ;;
    codex-python) echo "agent-python${tag}" ;;
    codex-swift) echo "agent-swift${tag}" ;;
    codex-office) echo "agent-office${tag}" ;;
    agent-plain|agent-python|agent-swift|agent-office) echo "${family}${tag}" ;;
    *) echo "$image" ;;
  esac
}

image_ref_for_runtime() {
  local image="$1"
  local preferred
  preferred="$(image_family_preferred "$image")"
  if image_exists "$preferred"; then
    echo "$preferred"
    return 0
  fi
  if image_exists "$image"; then
    echo "$image"
    return 0
  fi
  echo "$preferred"
}

is_codex_image_family() {
  case "$1" in
    codex|agent|agent-plain|agent-python|agent-swift|agent-office) return 0 ;;
    codex-*|agent-*)
      if is_codex_backup_image_ref "$1"; then
        return 1
      fi
      return 0
      ;;
    *) return 1 ;;
  esac
}

is_codex_image_filter_name() {
  local image_filter_name="$1"
  if is_codex_image_family "$image_filter_name"; then
    return 0
  fi
  if [[ "$image_filter_name" == codex-* || "$image_filter_name" == agent-* ]]; then
    return 0
  fi
  return 1
}

is_codex_backup_image_ref() {
  [[ "$1" =~ ^(codex|agent)-.*-backup-[0-9]{14}$ ]]
}

codex_backup_base() {
  local image_ref="$1"
  if [[ "$image_ref" =~ ^(.*)-backup-[0-9]{14}$ ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

image_ref_matches_filter() {
  local image_ref="$1"
  local image_filter="$2"
  local family
  local backup_base

  if [ -z "$image_filter" ]; then
    return 0
  fi

  family="${image_ref%%:*}"
  if is_codex_image_family "$family"; then
    [ "$family" = "$image_filter" ]
    return
  fi
  if ! is_codex_backup_image_ref "$family"; then
    return 1
  fi
  if [ "$family" = "$image_filter" ]; then
    return 0
  fi
  backup_base="$(codex_backup_base "$family")"
  if [ "$backup_base" = "$image_filter" ]; then
    return 0
  fi
  return 1
}

image_prune_group() {
  local image_ref="$1"
  local family
  family="${image_ref%%:*}"
  if is_codex_backup_image_ref "$family"; then
    if [[ "$family" =~ ^(.*-backup)-[0-9]{14}$ ]]; then
      echo "${BASH_REMATCH[1]}"
    else
      echo "$family"
    fi
    return
  fi
  echo "$family"
}

is_codex_image_ref() {
  local image_ref="$1"
  local family
  local tag=""

  family="$image_ref"
  if [[ "$image_ref" == *:* ]]; then
    family="${image_ref%%:*}"
    tag="${image_ref#*:}"
  fi
  if [ -z "$tag" ] || [ "$tag" = "latest" ]; then
    if is_codex_image_family "$family"; then
      return 0
    fi
    if is_codex_backup_image_ref "$family"; then
      return 0
    fi
    return 1
  fi
  is_codex_image_family "$family" || return 1
  [ -n "$(timestamp_for_image_ref "$image_ref")" ]
}

parse_image_list() {
  image_list | awk '
    NR == 1 { next }
    NF >= 2 {
      repo = $1
      tag = $2
      if (repo == "" || repo == "<none>" || tag == "" || tag == "<none>") {
        next
      }
      if (tag == "latest") {
        print repo
      } else {
        print repo ":" tag
      }
    }
  '
}

list_codex_image_families_from_refs() {
  local refs="$1"
  printf '%s\n' "$refs" | while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if is_codex_image_family "${ref%%:*}"; then
      echo "${ref%%:*}"
    fi
  done | sort -u
}

timestamp_for_image_ref() {
  local image_ref="$1"
  if [[ "$image_ref" =~ ^[^:]+:([0-9]{8}-[0-9]{6})$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi
  if [[ "$image_ref" =~ ^(.*)-backup-([0-9]{8})([0-9]{6})$ ]]; then
    echo "${BASH_REMATCH[2]}-${BASH_REMATCH[3]}"
  fi
}

default_name() {
  local prefix="$1"
  local path="${2:-$PWD}"
  echo "${prefix}$(sanitize_container_name "$(basename "$path")")"
}

sanitize_container_name() {
  local raw="$1"
  local sanitized
  sanitized="$(printf '%s' "$raw" | tr -cs 'A-Za-z0-9_.-' '-')"
  sanitized="${sanitized#-}"
  sanitized="${sanitized%-}"
  if [ -z "$sanitized" ]; then
    sanitized="workdir"
  fi
  echo "$sanitized"
}

sanitize_image_name() {
  local raw="$1"
  local sanitized
  sanitized="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9._/-' '-')"
  sanitized="${sanitized#-}"
  sanitized="${sanitized%-}"
  if [ -z "$sanitized" ]; then
    sanitized="agent-backup"
  fi
  echo "$sanitized"
}

