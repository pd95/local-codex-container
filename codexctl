      ;;
    *)
      if [ -n "$auth_format" ]; then
        printf 'runtime-%s-%s-auth\n' "$(sanitize_keychain_segment "$runtime")" "$(sanitize_keychain_segment "$auth_format")"
      else
        printf 'runtime-%s-auth\n' "$(sanitize_keychain_segment "$runtime")"
      fi
      ;;
  esac
}

run_keychain_for_runtime() {
  local runtime="${1:-$OPENAI_RUNTIME_ID}"
  local auth_format="${2:-$OPENAI_AUTH_FORMAT}"
  shift 2

  KEYCHAIN_SERVICE_NAME="$(runtime_keychain_service "$runtime" "$auth_format")" \
  KEYCHAIN_ACCOUNT_NAME="$(runtime_keychain_account "$runtime" "$auth_format")" \
  "$KEYCHAIN_SCRIPT" "$@"
}

auth_info_from_json() {
  local script
  script="$(cat <<'PY'
import json
import re
import sys

raw = sys.stdin.buffer.read()

def extract_from_json(payload):
    token = payload.get("refresh_token", "")
    if not token:
        tokens = payload.get("tokens", {})
        if isinstance(tokens, dict):
            token = tokens.get("refresh_token", "")
    if not token:
        claude = payload.get("claudeAiOauth", {})
        if isinstance(claude, dict):
            token = claude.get("refreshToken", "")
    last_refresh = payload.get("last_refresh", "")
    if not last_refresh:
        claude = payload.get("claudeAiOauth", {})
        if isinstance(claude, dict):
            expires_at = claude.get("expiresAt", "")
            if isinstance(expires_at, int):
                last_refresh = f"{expires_at:013d}"
            elif isinstance(expires_at, str) and expires_at.isdigit():
                last_refresh = expires_at.zfill(13)
    return token, last_refresh

try:
    data = json.loads(raw.decode("utf-8"))
    token, last_refresh = extract_from_json(data)
    print(f"{token}\t{last_refresh}")
except Exception:
    text = raw.decode("utf-8", "ignore")
    token_match = re.search(r'"refresh_token"\s*:\s*"([^"]+)"', text)
    if not token_match:
        token_match = re.search(r'"refreshToken"\s*:\s*"([^"]+)"', text)
    refresh_match = re.search(r'"last_refresh"\s*:\s*"([^"]+)"', text)
    if not refresh_match:
        refresh_match = re.search(r'"expiresAt"\s*:\s*([0-9]+)', text)
    token = token_match.group(1) if token_match else ""
    if refresh_match:
        raw_refresh = refresh_match.group(1)
        last_refresh = raw_refresh.zfill(13) if raw_refresh.isdigit() else raw_refresh
    else:
        last_refresh = ""
    print(f"{token}\t{last_refresh}")
PY
)"
  python_exec "$script"
}

keychain_auth_info() {
  local runtime="${1:-$OPENAI_RUNTIME_ID}"
  local auth_format="${2:-$OPENAI_AUTH_FORMAT}"
  run_keychain_for_runtime "$runtime" "$auth_format" read | auth_info_from_json
}

keychain_auth_blob() {
  local runtime="${1:-$OPENAI_RUNTIME_ID}"
  local auth_format="${2:-$OPENAI_AUTH_FORMAT}"
  run_keychain_for_runtime "$runtime" "$auth_format" read
}

write_keychain_auth_blob() {
  local runtime="${1:-$OPENAI_RUNTIME_ID}"
  local auth_format="${2:-$OPENAI_AUTH_FORMAT}"
  run_keychain_for_runtime "$runtime" "$auth_format" write
}

container_auth_blob() {
  local name="$1"
  local runtime="${2:-$OPENAI_RUNTIME_ID}"
  local auth_format="${3:-$OPENAI_AUTH_FORMAT}"
  if ! run_agent_sh_in_container "$name" auth read "$runtime" "$auth_format"; then
    return 0
  fi
}

write_auth_blob_to_container() {
  local name="$1"
  local payload="$2"
  local runtime="${3:-$OPENAI_RUNTIME_ID}"
  local auth_format="${4:-$OPENAI_AUTH_FORMAT}"
  local was_running=0
  local started_for_command=0

  if ! container_exists "$name"; then
    die "Container not found: $name"
  fi

  if container_running "$name"; then
    was_running=1
  else
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_command=1
  fi

  printf '%s' "$payload" | "$CONTAINER_CMD" exec -i "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh auth write "$runtime" "$auth_format"

  if [ "$started_for_command" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi
}

container_auth_info() {
  local name="$1"
  local runtime="${2:-$OPENAI_RUNTIME_ID}"
  local auth_format="${3:-$OPENAI_AUTH_FORMAT}"
  local blob
  blob="$(container_auth_blob "$name" "$runtime" "$auth_format")"
  if [ -z "$blob" ]; then
    echo -e "\t"
    return 0
  fi
  printf '%s' "$blob" | auth_info_from_json
}

sync_runtime_auth_to_container() {
  local name="$1"
  local runtime="${2:-$OPENAI_RUNTIME_ID}"
  local auth_format="${3:-$OPENAI_AUTH_FORMAT}"
  local missing_message="${4:-Missing runtime auth in Keychain. Run: ${CLI_NAME} auth --runtime $runtime}"
  if ! ensure_keychain "$runtime" "$auth_format"; then
    die "$missing_message"
  fi
  local keychain_info
  local keychain_token
  local keychain_refresh
  keychain_info="$(keychain_auth_info "$runtime" "$auth_format")"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  if [ -z "$keychain_token" ]; then
    die "$missing_message"
  fi
  local container_info
  local container_token
  local container_refresh
  container_info="$(container_auth_info "$name" "$runtime" "$auth_format")"
  IFS=$'\t' read -r container_token container_refresh <<<"$container_info"
  if [ -z "$container_token" ]; then
    echo "Refreshing $runtime auth in $name" >&2
    write_auth_blob_to_container "$name" "$(keychain_auth_blob "$runtime" "$auth_format")" "$runtime" "$auth_format"
    return 0
  fi
  if [ "$container_token" = "$keychain_token" ] && [ "$container_refresh" = "$keychain_refresh" ]; then
    return 0
  fi
  echo "Refreshing $runtime auth in $name" >&2
  write_auth_blob_to_container "$name" "$(keychain_auth_blob "$runtime" "$auth_format")" "$runtime" "$auth_format"
}

sync_runtime_auth_from_container() {
  local name="$1"
  local runtime="${2:-$OPENAI_RUNTIME_ID}"
  local auth_format="${3:-$OPENAI_AUTH_FORMAT}"
  local container_info
  local container_token
  local container_refresh
  container_info="$(container_auth_info "$name" "$runtime" "$auth_format")"
  IFS=$'\t' read -r container_token container_refresh <<<"$container_info"
  if [ -z "$container_token" ] || [ -z "$container_refresh" ]; then
    return 0
  fi
  if ! ensure_keychain "$runtime" "$auth_format"; then
    echo "Keychain auth missing; skipping post-run sync from $name" >&2
    return 0
  fi
  local keychain_info
  local keychain_token
  local keychain_refresh
  keychain_info="$(keychain_auth_info "$runtime" "$auth_format")"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  if [ -z "$keychain_token" ]; then
    echo "Keychain auth missing refresh_token; skipping post-run sync from $name" >&2
    return 0
  fi
  if [ -z "$keychain_refresh" ] || [[ "$container_refresh" < "$keychain_refresh" ]] || [ "$container_refresh" = "$keychain_refresh" ]; then
    return 0
  fi
  echo "Updating Keychain auth from $name" >&2
  container_auth_blob "$name" "$runtime" "$auth_format" | write_keychain_auth_blob "$runtime" "$auth_format"
}

sync_openai_auth_to_container() {
  local name="$1"
  sync_runtime_auth_to_container "$name" "$OPENAI_RUNTIME_ID" "$OPENAI_AUTH_FORMAT" "Missing OpenAI auth in Keychain. Run: ${CLI_NAME} auth"
}

sync_openai_auth_from_container() {
  local name="$1"
  sync_runtime_auth_from_container "$name" "$OPENAI_RUNTIME_ID" "$OPENAI_AUTH_FORMAT"
}

refresh_container_file() {
  local name="$1"
  local source="$2"
  local target="$3"
  local owner="${4:-root:root}"
  local mode="${5:-644}"
  local dir

  [ -f "$source" ] || die "Refresh source not found: $source"
  dir="$(dirname "$target")"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc "mkdir -p '$dir'"
  "$CONTAINER_CMD" exec -i -u 0 "$name" sh -lc "cat > '$target'" <"$source"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc "chmod $mode '$target' && chown $owner '$target'"
}

refresh_container_tree() {
  local name="$1"
  local source="$2"
  local target="$3"
  local owner="${4:-root:root}"
  local file_mode="${5:-644}"
  local dir_mode="${6:-755}"

  [ -d "$source" ] || die "Refresh source directory not found: $source"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc "mkdir -p '$target'"
  tar -C "$source" -cf - . | "$CONTAINER_CMD" exec -i -u 0 "$name" sh -lc "tar -xf - -C '$target'"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc "chown -R $owner '$target' && find '$target' -type d -exec chmod $dir_mode {} + && find '$target' -type f -exec chmod $file_mode {} +"
}

refresh_cmd() {
  local name=""
  local was_running=0
  local started_for_refresh=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --help) usage_refresh; return 0 ;;
      *) die "Unknown option for refresh: $1" ;;
    esac
  done

  require_container
  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi
  if ! container_exists "$name"; then
    die "Container not found: $name"
  fi

  if container_running "$name"; then
    was_running=1
  else
    echo "Starting container for refresh: $name" >&2
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_refresh=1
  fi

  refresh_container_file "$name" "$SCRIPT_DIR/agent.sh" "/usr/local/bin/agent.sh" "root:root" "755"
  refresh_container_file "$name" "$SCRIPT_DIR/config.toml" "/etc/agentctl/config.toml" "root:root" "644"
  refresh_container_file "$name" "$SCRIPT_DIR/local_models.json" "/etc/agentctl/local_models.json" "root:root" "644"
  refresh_container_file "$name" "$SCRIPT_DIR/config.toml" "/etc/codexctl/config.toml" "root:root" "644"
  refresh_container_file "$name" "$SCRIPT_DIR/local_models.json" "/etc/codexctl/local_models.json" "root:root" "644"
  refresh_container_file "$name" "$SCRIPT_DIR/claude-settings.json" "/etc/claudectl/settings.json" "root:root" "644"
  refresh_container_file "$name" "$SCRIPT_DIR/agentctl-path.sh" "/etc/profile.d/agentctl-path.sh" "root:root" "644"
  refresh_container_tree "$name" "$SCRIPT_DIR/runtimes" "/usr/local/lib/agentctl/runtimes" "root:root" "644" "755"
  refresh_container_tree "$name" "$SCRIPT_DIR/runtimes.d" "/etc/agentctl/runtimes.d" "root:root" "644" "755"
  if "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" test -x /usr/local/bin/agent.sh; then
    "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh refresh >/dev/null 2>&1 || true
  fi

  if [ "$started_for_refresh" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    echo "Stopping container: $name" >&2
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi
  echo "Refresh complete: $name" >&2
}

run_agent_sh_in_container() {
  local name="$1"
  shift
  local was_running=0
  local started_for_command=0
  local status=0

  if ! container_exists "$name"; then
    die "Container not found: $name"
  fi

  if container_running "$name"; then
    was_running=1
  else
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_command=1
  fi

  if "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh "$@"; then
    status=0
  else
    status=$?
  fi

  if [ "$started_for_command" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi

  return "$status"
}

runtime_cmd() {
  local name=""
  local subcommand=""
  local runtime=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --help) usage_runtime; return 0 ;;
      *)
        if [ -z "$subcommand" ]; then
          subcommand="$1"
        elif [ -z "$runtime" ]; then
          runtime="$1"
        else
          die "Unexpected argument for runtime: $1"
        fi
        shift
        ;;
    esac
  done

  require_container
  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  case "$subcommand" in
    list)
      run_agent_sh_in_container "$name" runtime list
      ;;
    info|capabilities|install|update|reset-config)
      [ -n "$runtime" ] || die "Missing runtime for $subcommand"
      run_agent_sh_in_container "$name" runtime "$subcommand" "$runtime"
      ;;
    "")
      usage_runtime
      ;;
    *)
      die "Unknown runtime command: $subcommand"
      ;;
  esac
}

use_cmd() {
