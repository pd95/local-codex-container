{
  "id": "claude",
  "command": "claude",
  "install_method": "native-installer",
  "default_config_dir": "/etc/claudectl",
  "capabilities": {
    "install": true,
    "update": true,
    "reset_config": true,
    "auth_login": true,
    "auth_read": true,
    "auth_write": true,
    "local_mode": true,
    "online_mode": true
  },
  "auth_formats": [
    "claude_ai_oauth_json"
  ],
  "commands": [
    "help",
    "run",
    "version",
    "refresh",
    "runtime list",
    "preferred get",
    "preferred set claude",
    "runtime info claude",
    "runtime capabilities claude",
    "runtime install claude",
    "runtime update claude",
    "runtime reset-config claude",
    "auth login claude",
    "auth read claude claude_ai_oauth_json",
    "auth write claude claude_ai_oauth_json",
    "system manifest"
  ]
}
