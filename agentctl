backup_known_state_from_container() {
  local name="$1"
  local backup_file="$2"
  local path_list=""

  path_list="$("$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" sh -lc '
for path in .codex .config/agentctl .claude .claude.json; do
  if [ -e "/home/coder/$path" ]; then
    printf "%s\n" "$path"
  fi
done
' 2>/dev/null || true)"
  [ -n "$path_list" ] || return 0

  "$CONTAINER_CMD" exec -i "$name" "${SETPRIV_ARGS[@]}" sh -lc '
cd /home/coder || exit 1
paths_file="$(mktemp)"
cat >"$paths_file"
if [ ! -s "$paths_file" ]; then
  rm -f "$paths_file"
  exit 0
fi
tar -cf - -T "$paths_file"
rm -f "$paths_file"
' >"$backup_file" <<<"$path_list"
}

container_supports_state_contract() {
  local name="$1"
  local was_running=0
  local started_for_check=0

  if container_running "$name"; then
    was_running=1
  else
    "$CONTAINER_CMD" start "$name" >/dev/null || return 1
    started_for_check=1
  fi

  if "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh help 2>/dev/null | grep -Fq 'agent.sh state export'; then
    if [ "$started_for_check" -eq 1 ] && [ "$was_running" -eq 0 ]; then
      "$CONTAINER_CMD" stop "$name" >/dev/null 2>&1 || true
    fi
    return 0
  fi
  if [ "$started_for_check" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    "$CONTAINER_CMD" stop "$name" >/dev/null 2>&1 || true
  fi
  return 1
}

export_root_supports_state_contract() {
  local extract_root="$1"
  local agent_script="$extract_root/usr/local/bin/agent.sh"

  [ -f "$agent_script" ] || return 1
  grep -Fq 'agent.sh state export' "$agent_script"
