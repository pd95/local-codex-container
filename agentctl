  if ! manifest="$("$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" cat "$SYSTEM_BASELINE_MANIFEST_FILE")"; then
    if [ "$started_for_manifest" -eq 1 ] && [ "$was_running" -eq 0 ]; then
      "$CONTAINER_CMD" stop "$name" >/dev/null 2>&1 || true
    fi
    return 1
  fi
  if [ "$started_for_manifest" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi
  [ -n "$manifest" ] || return 1
  printf '%s\n' "$manifest"
}

temporary_system_manifest_container_name() {
  local role="${1:-image}"

  sanitize_container_name "${CLI_NAME}-system-manifest-${role}-$$-${RANDOM:-0}"
}

image_system_manifest_json() {
  local image="$1"
  local role="${2:-image}"
  local temp_name=""
  local created=0
  local started=0
  local manifest=""

  temp_name="$(temporary_system_manifest_container_name "$role")"
  if ! "$CONTAINER_CMD" create -t --name "$temp_name" "$image" sh -c 'sleep infinity' >/dev/null; then
    return 1
  fi
  created=1

  if ! "$CONTAINER_CMD" start "$temp_name" >/dev/null; then
    if [ "$created" -eq 1 ]; then
      "$CONTAINER_CMD" rm "$temp_name" >/dev/null 2>&1 || true
    fi
    return 1
  fi
  started=1

  if ! manifest="$("$CONTAINER_CMD" exec "$temp_name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh system manifest)"; then
    if [ "$started" -eq 1 ]; then
      "$CONTAINER_CMD" stop "$temp_name" >/dev/null 2>&1 || true
    fi
    if [ "$created" -eq 1 ]; then
      "$CONTAINER_CMD" rm "$temp_name" >/dev/null 2>&1 || true
    fi
    return 1
  fi

  if [ "$started" -eq 1 ]; then
    "$CONTAINER_CMD" stop "$temp_name" >/dev/null 2>&1 || true
  fi
  if [ "$created" -eq 1 ]; then
    "$CONTAINER_CMD" rm "$temp_name" >/dev/null 2>&1 || true
  fi

  printf '%s\n' "$manifest"
}

upgrade_source_manifest_json() {
  local name="$1"
  local current_image="$2"
  local target_image="$3"
  local target_manifest="${4:-}"
  local stored_manifest=""
  local source_manifest=""

  if stored_manifest="$(container_baseline_manifest_json "$name")"; then
    source_manifest="$stored_manifest"
  elif [ "$current_image" = "$target_image" ] && [ -n "$target_manifest" ]; then
    source_manifest="$target_manifest"
  elif image_exists "$current_image"; then
    if ! source_manifest="$(image_system_manifest_json "$current_image" source)"; then
      return 1
    fi
  else
    return 1
  fi

  [ -n "$source_manifest" ] || return 1
  printf '%s\n' "$source_manifest"
}

upgrade_added_runtimes_json() {
  local name="$1"
  local current_image="$2"
  local target_image="$3"
  local current_manifest=""
  local source_manifest=""
  local target_manifest=""

  current_manifest="$(container_system_manifest_json "$name")" || return 1
  target_manifest="$(image_system_manifest_json "$target_image" target)" || return 1
  source_manifest="$(upgrade_source_manifest_json "$name" "$current_image" "$target_image" "$target_manifest")" || return 1

  json_string_array_difference \
    "$(json_string_array_difference "$(manifest_installed_runtimes_json "$current_manifest")" "$(manifest_installed_runtimes_json "$source_manifest")")" \
    "$(manifest_installed_runtimes_json "$target_manifest")"
}

upgrade_added_features_json() {
  local name="$1"
  local current_image="$2"
  local target_image="$3"
  local current_manifest=""
  local source_manifest=""
  local target_manifest=""

  current_manifest="$(container_system_manifest_json "$name")" || return 1
  target_manifest="$(image_system_manifest_json "$target_image" target)" || return 1
  source_manifest="$(upgrade_source_manifest_json "$name" "$current_image" "$target_image" "$target_manifest")" || return 1

  json_string_array_difference \
    "$(json_string_array_difference "$(manifest_installed_features_json "$current_manifest")" "$(manifest_installed_features_json "$source_manifest")")" \
    "$(manifest_installed_features_json "$target_manifest")"
