bootstrap_cmd() {
  local name=""
  local image=""
  local workdir=""
  local cpu=""
  local mem=""
  local was_running=0
  local started_for_bootstrap=0
  local created_for_bootstrap=0
  local package_manager=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --image) image="$2"; shift 2 ;;
      --workdir) workdir="$2"; shift 2 ;;
      --cpu) cpu="$2"; shift 2 ;;
      --mem) mem="$2"; shift 2 ;;
      --help) usage_bootstrap; return 0 ;;
      *) die "Unknown option for bootstrap: $1" ;;
    esac
  done

  require_container
  if [ -z "$name" ]; then
    if [ -z "$workdir" ]; then
      name="$(default_name "$DEFAULT_NAME_PREFIX")"
    else
      name="$(default_name "$DEFAULT_NAME_PREFIX" "$workdir")"
    fi
  fi

  if [ -n "$workdir" ]; then
    [ -d "$workdir" ] || die "Workdir not found: $workdir"
    workdir="$(CDPATH= cd -- "$workdir" && pwd)"
  else
    workdir="$PWD"
  fi

  if container_exists "$name"; then
    if [ -n "$image" ] || [ -n "$cpu" ] || [ -n "$mem" ]; then
      die "--image, --cpu, and --mem only apply when bootstrap creates a new container"
    fi
  else
    [ -n "$image" ] || die "Container not found: $name (pass --image to create and bootstrap a new container)"
    echo "Creating bootstrap container..." >&2
    local create_cmd=("$CONTAINER_CMD" create -t)
    if [ -n "$cpu" ]; then
      create_cmd+=(-c "$cpu")
    fi
    if [ -n "$mem" ]; then
      create_cmd+=(-m "$mem")
    fi
    create_cmd+=(
      --name "$name"
      --mount "type=bind,src=$workdir,dst=/workdir"
      "$image" sh -c 'sleep infinity'
    )
    "${create_cmd[@]}"
    created_for_bootstrap=1
  fi

  if container_running "$name"; then
    was_running=1
  else
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_bootstrap=1
  fi

  package_manager="$("$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'if command -v apk >/dev/null 2>&1; then echo apk; elif command -v apt-get >/dev/null 2>&1; then echo apt-get; else echo unsupported; fi')"
  case "$package_manager" in
    apk)
      bootstrap_container_alpine "$name"
      ;;
    apt-get)
      bootstrap_container_apt "$name"
      ;;
    *)
      if [ "$started_for_bootstrap" -eq 1 ] && [ "$was_running" -eq 0 ]; then
        "$CONTAINER_CMD" stop "$name" >/dev/null
      fi
      die "Unsupported bootstrap container base for current bootstrap slice: $name (need Alpine/apk or Debian/Ubuntu apt-get)"
      ;;
  esac

  if [ "$started_for_bootstrap" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi
  if [ "$created_for_bootstrap" -eq 1 ]; then
    echo "Bootstrap container ready: $name" >&2
  fi
  echo "Bootstrap complete: $name" >&2
}

refresh_cmd() {
  local name=""
