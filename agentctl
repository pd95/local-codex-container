json_string_array_difference() {
  local left_json="${1:-[]}"
  local right_json="${2:-[]}"

  jq -cn \
    --arg left_json "$left_json" \
    --arg right_json "$right_json" \
    '
      (($left_json | fromjson? // [])) as $left
      | (($right_json | fromjson? // [])) as $right
      | ($right | map({key: ., value: true}) | from_entries) as $right_index
      | [($left // [])[] | select($right_index[.] != true)]
      | unique
      | sort
    '
}

