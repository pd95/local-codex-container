  run_keychain_for_runtime "$runtime" "$auth_format" write
}

container_auth_blob() {
  local name="$1"
  local runtime="${2:-$DEFAULT_RUNTIME}"
  local auth_format="$3"
  if ! run_agent_sh_in_container "$name" auth read "$runtime" "$auth_format"; then
    return 0
  fi
}

write_auth_blob_to_container() {
  local name="$1"
  local payload="$2"
  local runtime="${3:-$DEFAULT_RUNTIME}"
  local auth_format="$4"
  local was_running=0
  local started_for_command=0
  local status=0
  local stderr_file=""

  if ! container_exists "$name"; then
    die "Container not found: $name"
  fi

  if container_running "$name"; then
    was_running=1
  else
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_command=1
  fi

  stderr_file="$(mktemp)"
  if printf '%s' "$payload" | "$CONTAINER_CMD" exec -i "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh auth write "$runtime" "$auth_format" 2>"$stderr_file"; then
    status=0
  elif legacy_write_auth_blob_to_container "$name" "$payload" "$runtime" "$auth_format"; then
    warn "Using legacy Codex auth refresh fallback for $name. Run: ${CLI_NAME} refresh --name $name"
    status=0
  else
    cat "$stderr_file" >&2
    status=1
  fi
  rm -f "$stderr_file"

  if [ "$started_for_command" -eq 1 ] && [ "$was_running" -eq 0 ]; then
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi

  return "$status"
}

legacy_write_auth_blob_to_container() {
  local name="$1"
  local payload="$2"
  local runtime="${3:-$DEFAULT_RUNTIME}"
  local auth_format="$4"

  case "$runtime:$auth_format" in
    codex:json_refresh_token)
      "$CONTAINER_CMD" exec -i -u 0 "$name" sh -lc 'mkdir -p /home/coder/.codex && cat > /home/coder/.codex/auth.json && chown -R coder:coder /home/coder/.codex' <<<"$payload"
      ;;
    *)
      return 1
      ;;
  esac
}

container_auth_info() {
  local name="$1"
  local runtime="${2:-$DEFAULT_RUNTIME}"
  local auth_format="$3"
  local blob
  blob="$(container_auth_blob "$name" "$runtime" "$auth_format")"
  if [ -z "$blob" ]; then
    echo -e "\t"
    return 0
  fi
  printf '%s' "$blob" | auth_info_from_json
}

sync_runtime_auth_to_container() {
  local name="$1"
  local runtime="${2:-$DEFAULT_RUNTIME}"
  local auth_format="$3"
  local missing_message="${4:-Missing runtime auth in Keychain. Run: ${CLI_NAME} auth --runtime $runtime}"
  if ! ensure_keychain "$runtime" "$auth_format"; then
    die "$missing_message"
  fi
  local keychain_info
  local keychain_token
  local keychain_refresh
  keychain_info="$(keychain_auth_info "$runtime" "$auth_format")"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  if [ -z "$keychain_token" ]; then
    die "$missing_message"
  fi
  local container_info
  local container_token
  local container_refresh
  container_info="$(container_auth_info "$name" "$runtime" "$auth_format")"
  IFS=$'\t' read -r container_token container_refresh <<<"$container_info"
  if [ -z "$container_token" ]; then
    echo "Refreshing $runtime auth in $name" >&2
    write_auth_blob_to_container "$name" "$(keychain_auth_blob "$runtime" "$auth_format")" "$runtime" "$auth_format"
    return 0
  fi
  if [ "$container_token" = "$keychain_token" ] && [ "$container_refresh" = "$keychain_refresh" ]; then
    return 0
  fi
  echo "Refreshing $runtime auth in $name" >&2
  write_auth_blob_to_container "$name" "$(keychain_auth_blob "$runtime" "$auth_format")" "$runtime" "$auth_format"
}

sync_runtime_auth_from_container() {
  local name="$1"
  local runtime="${2:-$DEFAULT_RUNTIME}"
  local auth_format="$3"
  local container_info
  local container_token
  local container_refresh
  container_info="$(container_auth_info "$name" "$runtime" "$auth_format")"
  IFS=$'\t' read -r container_token container_refresh <<<"$container_info"
  if [ -z "$container_token" ] || [ -z "$container_refresh" ]; then
    return 0
  fi
  if ! ensure_keychain "$runtime" "$auth_format"; then
    echo "Keychain auth missing; skipping post-run sync from $name" >&2
    return 0
  fi
  local keychain_info
  local keychain_token
  local keychain_refresh
  keychain_info="$(keychain_auth_info "$runtime" "$auth_format")"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  if [ -z "$keychain_token" ]; then
    echo "Keychain auth missing refresh_token; skipping post-run sync from $name" >&2
    return 0
  fi
  if [ -z "$keychain_refresh" ] || [[ "$container_refresh" < "$keychain_refresh" ]] || [ "$container_refresh" = "$keychain_refresh" ]; then
    return 0
  fi
  echo "Updating Keychain auth from $name" >&2
  container_auth_blob "$name" "$runtime" "$auth_format" | write_keychain_auth_blob "$runtime" "$auth_format"
}

runtime_info_in_container() {
  local name="$1"
  local runtime="$2"

  "$CONTAINER_CMD" exec "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh runtime info "$runtime"
}

sync_runtime_auth_to_container_if_available() {
  local name="$1"
  local runtime="$2"
  local runtime_info=""
  local auth_format=""
  local keychain_info=""
  local keychain_token=""
  local keychain_refresh=""

  runtime_info="$(runtime_info_in_container "$name" "$runtime" 2>/dev/null || true)"
  [ -n "$runtime_info" ] || return 0
  if ! printf '%s' "$runtime_info" | jq -e '.installed == true and (.capabilities.auth_read // false) and (.capabilities.auth_write // false)' >/dev/null 2>&1; then
    return 0
  fi
  auth_format="$(printf '%s' "$runtime_info" | jq -er '.auth_formats[0] // empty' 2>/dev/null || true)"
  [ -n "$auth_format" ] || return 0
  if ! ensure_keychain "$runtime" "$auth_format"; then
    return 0
  fi
  keychain_info="$(keychain_auth_info "$runtime" "$auth_format" 2>/dev/null || true)"
  IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
  [ -n "$keychain_token" ] || return 0
  sync_runtime_auth_to_container "$name" "$runtime" "$auth_format" "Missing runtime auth in Keychain. Run: ${CLI_NAME} auth --runtime $runtime"
}

sync_runtime_auth_from_container_if_available() {
  local name="$1"
  local runtime="$2"
  local runtime_info=""
  local auth_format=""

  runtime_info="$(runtime_info_in_container "$name" "$runtime" 2>/dev/null || true)"
  [ -n "$runtime_info" ] || return 0
  if ! printf '%s' "$runtime_info" | jq -e '.installed == true and (.capabilities.auth_read // false)' >/dev/null 2>&1; then
    return 0
  fi
  auth_format="$(printf '%s' "$runtime_info" | jq -er '.auth_formats[0] // empty' 2>/dev/null || true)"
  [ -n "$auth_format" ] || return 0
  sync_runtime_auth_from_container "$name" "$runtime" "$auth_format"
}

runtime_config_json_from_entries() {
  local config_json='{}'
  local entry=""
  local key=""
  local value=""

  for entry in "$@"; do
    case "$entry" in
      *=*)
        key="${entry%%=*}"
        value="${entry#*=}"
        ;;
      *)
        die "Invalid runtime config: $entry (expected key=value)"
        ;;
    esac
    [ -n "$key" ] || die "Invalid runtime config: $entry (expected non-empty key)"
    config_json="$(printf '%s' "$config_json" | jq -c --arg key "$key" --arg value "$value" '. + {($key): $value}')" || die "Failed to encode runtime config: $entry"
  done

  printf '%s\n' "$config_json"
}

runtime_config_value_from_json() {
  local config_json="${1:-{}}"
  local key="$2"
  local default_value="${3:-}"
  local value=""

  value="$(printf '%s' "$config_json" | jq -er --arg key "$key" '.[$key] // empty' 2>/dev/null || true)"
  if [ -n "$value" ]; then
    printf '%s\n' "$value"
    return 0
  fi
  printf '%s\n' "$default_value"
}

container_image_name() {
  local name="$1"
  local inspect_info=""

  inspect_info="$("$CONTAINER_CMD" inspect "$name" 2>/dev/null | container_upgrade_info)"
  printf '%s\n' "${inspect_info%%$'\t'*}"
}

resolve_auth_image_for_container() {
  local name="$1"
  local fallback_image="$2"
  local image=""

  if container_exists "$name"; then
    image="$(container_image_name "$name")"
  fi
  if [ -z "$image" ]; then
    image="$fallback_image"
  fi
  printf '%s\n' "$image"
}

refresh_container_file() {
  local name="$1"
  local source="$2"
  local target="$3"
  local owner="${4:-root:root}"
  local mode="${5:-644}"
  local dir

  [ -f "$source" ] || die "Refresh source not found: $source"
  dir="$(dirname "$target")"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc "mkdir -p '$dir'"
