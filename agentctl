images_print_latest() {
  local refs="$1"
  local image_filter="$2"
  local backup_only="$3"
  local family
  local family_refs
  local newest
  local backup_bases
  local backup_base
  local backup_family_refs

  if [ "$backup_only" -eq 1 ]; then
    backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
      if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
        continue
      fi
      if [ -n "$image_filter" ] && ! image_ref_matches_filter "$family_ref" "$image_filter"; then
        continue
      fi
      image_prune_group "$family_ref"
    done | sort -u)"
    [ -z "$backup_bases" ] && return 0

    while IFS= read -r backup_base; do
      [ -z "$backup_base" ] && continue
      backup_family_refs="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
        if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
          continue
        fi
        if [ "$backup_base" != "$(image_prune_group "$family_ref")" ]; then
          continue
        fi
        echo "$family_ref"
      done | sort -r || true)"
      if [ -n "$backup_family_refs" ]; then
        printf '%s\n' "$backup_family_refs"
      fi
    done <<< "$backup_bases"
    return 0
  fi

  while IFS= read -r family; do
    [ -z "$family" ] && continue
    if [ -n "$image_filter" ] && ! image_ref_matches_filter "$family" "$image_filter"; then
      continue
    fi
    family_refs="$(printf '%s\n' "$refs" | awk -F: -v family="$family" '$1 == family { print }' || true)"
    [ -z "$family_refs" ] && continue
    if printf '%s\n' "$family_refs" | grep -qx "$family"; then
      echo "$family"
    fi
    newest="$(printf '%s\n' "$family_refs" | grep -E "^${family}:[0-9]{8}-[0-9]{6}$" | sort -r | head -n 1 || true)"
    if [ -n "$newest" ]; then
      echo "$newest"
    fi
  done <<< "$(list_codex_image_families_from_refs "$refs")"

  backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
    if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
      continue
    fi
    if [ -n "$image_filter" ] && ! image_ref_matches_filter "$family_ref" "$image_filter"; then
      continue
    fi
    image_prune_group "$family_ref"
  done | sort -u)"
  [ -z "$backup_bases" ] && return 0

  while IFS= read -r backup_base; do
    [ -z "$backup_base" ] && continue
    backup_family_refs="$(printf '%s\n' "$refs" | while IFS= read -r family_ref; do
      if ! is_codex_backup_image_ref "${family_ref%%:*}"; then
        continue
      fi
      if [ "$backup_base" != "$(image_prune_group "$family_ref")" ]; then
        continue
      fi
      echo "$family_ref"
    done || true)"
    if [ -z "$backup_family_refs" ]; then
      continue
    fi
    newest="$(printf '%s\n' "$backup_family_refs" | sort -r | head -n 1 || true)"
    if [ -n "$newest" ]; then
      echo "$newest"
    fi
  done <<< "$backup_bases"
}

images_print_sorted() {
  local refs="$1"
  local include_all="$2"
  local image_filter="$3"
  local backup_only="$4"
  local family
  local family_refs
  local non_family_refs
  local backup_bases
  local backup_refs
  local backup_base
  local backup_ref

  if [ "$backup_only" -eq 1 ]; then
    backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
      if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
        continue
      fi
      if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
        continue
      fi
      image_prune_group "$backup_ref"
    done | sort -u || true)"
    if [ -n "$backup_bases" ]; then
      while IFS= read -r backup_base; do
        [ -z "$backup_base" ] && continue
        backup_refs="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
          if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
            continue
          fi
          if [ "$backup_base" != "$(image_prune_group "$backup_ref")" ]; then
            continue
          fi
          if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
            continue
          fi
          echo "$backup_ref"
        done | sort -r || true)"
        if [ -n "$backup_refs" ]; then
          printf '%s\n' "$backup_refs"
        fi
      done <<< "$backup_bases"
    fi
    return 0
  fi

  while IFS= read -r family; do
    [ -z "$family" ] && continue
    family_refs="$(printf '%s\n' "$refs" | awk -F: -v family="$family" '$1 == family { print }' || true)"
    if [ -n "$image_filter" ]; then
      family_refs="$(printf '%s\n' "$family_refs" | while IFS= read -r family_ref; do
        if image_ref_matches_filter "$family_ref" "$image_filter"; then
          echo "$family_ref"
        fi
      done || true)"
    fi
    [ -z "$family_refs" ] && continue
    if printf '%s\n' "$family_refs" | grep -qx "$family"; then
      echo "$family"
    fi
    printf '%s\n' "$family_refs" | awk -F: '$2 ~ /^[0-9]{8}-[0-9]{6}$/ { print }' | sort -r
    printf '%s\n' "$family_refs" | awk -F: '$2 != "" && $2 !~ /^[0-9]{8}-[0-9]{6}$/ { print }'
  done <<< "$(list_codex_image_families_from_refs "$refs")"

  if [ "$include_all" -eq 1 ] && [ -z "$image_filter" ]; then
    non_family_refs="$(printf '%s\n' "$refs" | while IFS= read -r ref; do
      [ -z "$ref" ] && continue
      if ! is_codex_image_ref "$ref"; then
        echo "$ref"
      fi
    done || true)"
    if [ -n "$non_family_refs" ]; then
      printf '%s\n' "$non_family_refs"
    fi
  fi

  backup_bases="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
    if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
      continue
    fi
    if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
      continue
    fi
    image_prune_group "$backup_ref"
  done | sort -u || true)"
  if [ -n "$backup_bases" ]; then
    while IFS= read -r backup_base; do
      [ -z "$backup_base" ] && continue
      backup_refs="$(printf '%s\n' "$refs" | while IFS= read -r backup_ref; do
        if ! is_codex_backup_image_ref "${backup_ref%%:*}"; then
          continue
        fi
        if [ "$backup_base" != "$(image_prune_group "$backup_ref")" ]; then
          continue
        fi
        if [ -n "$image_filter" ] && ! image_ref_matches_filter "$backup_ref" "$image_filter"; then
          continue
        fi
        echo "$backup_ref"
      done | sort -r || true)"
      if [ -n "$backup_refs" ]; then
        printf '%s\n' "$backup_refs"
      fi
    done <<< "$backup_bases"
  fi
}

remove_image_ref() {
  local image_ref="$1"
  if "$CONTAINER_CMD" image rm "$image_ref" >/dev/null 2>&1; then
    return 0
  fi
  if "$CONTAINER_CMD" image delete "$image_ref" >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

images_list_cmd() {
  local image=""
  local backup=0
  local include_all=0
  local latest=0
  local refs=""
  local filtered_refs=""
  local ref

  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --backup) backup=1; shift ;;
      --all) include_all=1; shift ;;
      --latest) latest=1; shift ;;
      --help) usage_images; return 0 ;;
      *) die "Unknown option for images: $1" ;;
    esac
  done
  if [ -n "$image" ] && ! is_codex_image_filter_name "$image"; then
    die "Unknown image: $image"
  fi
  if [ "$include_all" -eq 1 ] && [ "$latest" -eq 1 ]; then
    die "Cannot combine --all with --latest"
  fi
  require_container

  refs="$(parse_image_list || true)"
  while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if [ "$include_all" -eq 0 ] && ! is_codex_image_ref "$ref"; then
      continue
    fi
    if [ -n "$image" ] && ! image_ref_matches_filter "$ref" "$image"; then
      continue
    fi
    if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "$ref"; then
      continue
    fi
    filtered_refs="${filtered_refs}${ref}"$'\n'
  done <<< "$refs"
  filtered_refs="${filtered_refs%$'\n'}"
  [ -z "$filtered_refs" ] && return 0

  if [ "$latest" -eq 1 ]; then
    images_print_latest "$filtered_refs" "$image" "$backup"
    return 0
  fi
  images_print_sorted "$filtered_refs" "$include_all" "$image" "$backup"
}

images_prune_cmd() {
  local image=""
  local keep=1
  local backup=0
  local dry_run=0
  local refs=""
  local family_refs=""
  local to_remove=""
  local kept=0
  local failures=0
  local ref=""
  local family=""
  local deletion_ref=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --keep) keep="$2"; shift 2 ;;
      --backup) backup=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      --help) usage_images_prune; return 0 ;;
      *) die "Unknown option for images prune: $1" ;;
    esac
  done
  if ! [[ "$keep" =~ ^[0-9]+$ ]]; then
    die "--keep must be a non-negative integer: $keep"
  fi
  if [ -n "$image" ] && ! is_codex_image_filter_name "$image"; then
    die "Unknown image: $image"
  fi
  require_container

  refs="$(parse_image_list || true)"
  for family in $(printf '%s\n' "$refs" | while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if [ -z "$(timestamp_for_image_ref "$ref")" ]; then
      continue
    fi
    if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "$ref"; then
      continue
    fi
    if [ -n "$image" ] && ! image_ref_matches_filter "$ref" "$image"; then
      continue
    fi
    image_prune_group "$ref"
  done | sort -u || true); do
    [ -z "$family" ] && continue
    family_refs=""
    while IFS= read -r ref; do
      [ -z "$ref" ] && continue
      if [ "$(image_prune_group "$ref")" != "$family" ]; then
        continue
      fi
      if [ -z "$(timestamp_for_image_ref "$ref")" ]; then
        continue
      fi
      if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "$ref"; then
        continue
      fi
      if [ -n "$image" ] && ! image_ref_matches_filter "$ref" "$image"; then
        continue
      fi
      family_refs="${family_refs}${ref}"$'\n'
    done <<< "$refs"
    family_refs="${family_refs%$'\n'}"
    [ -z "$family_refs" ] && continue
    kept=0
    while IFS= read -r ref; do
      if [ "$kept" -lt "$keep" ]; then
        kept=$((kept + 1))
        continue
      fi
      to_remove="${to_remove}${ref}"$'\n'
    done <<< "$(printf '%s\n' "$family_refs" | sort -r || true)"
  done

  to_remove="${to_remove%$'\n'}"
  [ -z "$to_remove" ] && echo "No images to prune" && return 0

  while IFS= read -r deletion_ref; do
    [ -z "$deletion_ref" ] && continue
    if [ "$dry_run" -eq 1 ]; then
      echo "Would remove image: $deletion_ref"
      continue
    fi
    if remove_image_ref "$deletion_ref"; then
      echo "Removed image: $deletion_ref"
    else
      echo "Failed to remove image: $deletion_ref" >&2
      failures=$((failures + 1))
    fi
  done <<< "$to_remove"

  if [ "$failures" -ne 0 ]; then
    return 1
  fi

  return 0
}

images_rm_cmd() {
  local image=""
  local backup=0
  local dry_run=0
  local refs=""
  local to_remove=""
  local failures=0
  local ref=""
  local deletion_ref=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --backup) backup=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      --help) usage_images_rm; return 0 ;;
      *) die "Unknown option for images rm: $1" ;;
    esac
  done
  [ -n "$image" ] || die "--image is required for images rm"
  if ! is_codex_image_filter_name "$image"; then
    die "Unknown image: $image"
  fi
  require_container

  refs="$(parse_image_list || true)"
  while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    if ! image_ref_matches_filter "$ref" "$image"; then
      continue
    fi
    if [ "$backup" -eq 1 ] && ! is_codex_backup_image_ref "${ref%%:*}"; then
      continue
    fi
    to_remove="${to_remove}${ref}"$'\n'
  done <<< "$refs"

  to_remove="${to_remove%$'\n'}"
  [ -z "$to_remove" ] && echo "No images to remove" && return 0

  while IFS= read -r deletion_ref; do
    [ -z "$deletion_ref" ] && continue
    if [ "$dry_run" -eq 1 ]; then
      echo "Would remove image: $deletion_ref"
      continue
    fi
    if remove_image_ref "$deletion_ref"; then
      echo "Removed image: $deletion_ref"
    else
      echo "Failed to remove image: $deletion_ref" >&2
      failures=$((failures + 1))
    fi
  done <<< "$(printf '%s\n' "$to_remove" | sort -r || true)"

  if [ "$failures" -ne 0 ]; then
    return 1
  fi

  return 0
}

images_cmd() {
  if [ "$#" -gt 0 ] && [ "${1:0:2}" != "--" ]; then
    case "$1" in
      prune) shift; images_prune_cmd "$@" ;;
      rm) shift; images_rm_cmd "$@" ;;
      --help|-h) usage_images; return 0 ;;
      *) die "Unknown images subcommand: $1" ;;
    esac
  else
    images_list_cmd "$@"
  fi
}

build_cmd() {
  local image=""
  local runtimes_csv="$DEFAULT_RUNTIME"
  local runtimes_overridden=0
  local default_runtime="$DEFAULT_RUNTIME"
  local default_runtime_overridden=0
  local rebuild=0
  local snapshot=0
  local refresh_base=0
  local pull_base=0
  local no_cache=""
  local build_stamp
  local first_runtime=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --runtimes) runtimes_csv="$2"; runtimes_overridden=1; shift 2 ;;
      --default-runtime) default_runtime="$2"; default_runtime_overridden=1; shift 2 ;;
      --rebuild) rebuild=1; shift ;;
      --snapshot) snapshot=1; shift ;;
      --refresh-base) refresh_base=1; shift ;;
      --pull-base) pull_base=1; shift ;;
      --help) usage_build; return 0 ;;
      *) echo "Error: Unknown option for build: $1" >&2; usage_build; return 1 ;;
    esac
  done

  if [ -n "$image" ]; then
    image="$(image_family_preferred "$image")"
    warn_legacy_compat_image_usage "$image"
  fi

  normalize_build_runtime_csv() {
    local raw="$1"
    local entry=""
    local normalized=""
    local first=""
    local duplicate_guard=$'\n'
    local IFS=','
    read -r -a build_runtimes <<<"$raw"

    for entry in "${build_runtimes[@]}"; do
      entry="${entry#"${entry%%[![:space:]]*}"}"
      entry="${entry%"${entry##*[![:space:]]}"}"
      [ -n "$entry" ] || continue
      [ -f "$SCRIPT_DIR/runtimes.d/${entry}.json" ] || die "Unknown runtime for build: $entry"
      if printf '%s' "$duplicate_guard" | grep -Fqx -- "$entry"; then
        continue
      fi
      duplicate_guard="${duplicate_guard}${entry}"$'\n'
      if [ -z "$first" ]; then
        first="$entry"
      fi
      if [ -n "$normalized" ]; then
        normalized="${normalized},${entry}"
      else
        normalized="$entry"
      fi
    done

    [ -n "$normalized" ] || die "No valid runtimes provided for build"
    printf '%s\t%s\n' "$normalized" "$first"
  }

  if [ "$runtimes_overridden" -eq 0 ] && [ "$default_runtime_overridden" -eq 1 ]; then
    runtimes_csv="$default_runtime"
  fi

  IFS=$'\t' read -r runtimes_csv first_runtime <<<"$(normalize_build_runtime_csv "$runtimes_csv")"
  if [ "$default_runtime_overridden" -eq 0 ]; then
    default_runtime="$first_runtime"
  fi
  if [ ! -f "$SCRIPT_DIR/runtimes.d/${default_runtime}.json" ]; then
    die "Unknown runtime for build: $default_runtime"
  fi
  if ! printf ',%s,' "$runtimes_csv" | grep -Fq ",$default_runtime,"; then
    die "--default-runtime must be included in --runtimes"
  fi
  if { [ "$default_runtime_overridden" -eq 1 ] || [ "$runtimes_overridden" -eq 1 ]; } && [ "$snapshot" -eq 1 ]; then
    die "--runtimes and --default-runtime cannot be combined with --snapshot"
  fi

  require_container
  if [ "$rebuild" -eq 1 ]; then
    no_cache="--no-cache"
  fi
  build_stamp="$(date -u +%Y%m%d-%H%M%S)"

  remove_image() {
    local name="$1"
    if "$CONTAINER_CMD" image rm "$name" >/dev/null 2>&1; then
      echo "Removed base image: $name"
      return 0
    fi
    if "$CONTAINER_CMD" image delete "$name" >/dev/null 2>&1; then
      echo "Removed base image: $name"
      return 0
    fi
    echo "Base image not removed (may not exist or command unsupported): $name" >&2
  }

  is_local_agent_build_image() {
    case "$1" in
      agent-plain|agent-python|agent-swift|agent-office|agent-*) return 0 ;;
      codex|codex-python|codex-swift|codex-office) return 0 ;;
      *) return 1 ;;
    esac
  }

  dockerfile_name_for_image() {
    local name="$1"
    name="$(image_family_preferred "$name")"
    case "$name" in
      agent|agent-plain) echo "DockerFile" ;;
      agent-*) echo "DockerFile.${name#agent-}" ;;
      *) return 1 ;;
    esac
  }

  dockerfile_path_for_image() {
    local name="$1"
    local file
    file="$(dockerfile_name_for_image "$name")" || return 1
    echo "$SCRIPT_DIR/$file"
  }

  local_image_for_dockerfile_name() {
    local file_name="$1"
    case "$file_name" in
      DockerFile) echo "agent-plain" ;;
      DockerFile.python) echo "agent-python" ;;
      DockerFile.swift) echo "agent-swift" ;;
      DockerFile.office) echo "agent-office" ;;
      DockerFile.*) echo "agent-${file_name#DockerFile.}" ;;
      *) return 1 ;;
    esac
  }

  local_dockerfile_exists_for_image() {
    local image_name="$1"
    local file_path
    if ! file_path="$(dockerfile_path_for_image "$image_name")"; then
      return 1
    fi
    [ -f "$file_path" ]
  }

  list_local_build_images() {
    local file_path
    local file_name
    local image_name

    for file_path in "$SCRIPT_DIR"/DockerFile*; do
      [ -e "$file_path" ] || continue
      [ -f "$file_path" ] || continue
      file_name="$(basename "$file_path")"
      case "$file_name" in
        DockerFile|DockerFile.python|DockerFile.swift)
          image_name="$(local_image_for_dockerfile_name "$file_name" || true)"
          [ -n "$image_name" ] && printf '%s\n' "$image_name"
          ;;
      esac
    done | sort -u
  }

  base_image_from_file() {
    awk '
      toupper($1) == "FROM" {
        for (i = 2; i <= NF; i++) {
          if ($i ~ /^--/) {
            continue
          }
          print $i
          exit
        }
      }
    ' "$1"
  }

  refresh_base_image() {
    local file="$1"
    local base
    base="$(base_image_from_file "$file")"
    if [ -n "$base" ]; then
      base="$(image_family_preferred "$base")"
    fi
    if [ -n "$base" ]; then
      if local_dockerfile_exists_for_image "$base"; then
        echo "Skipping base image removal for local image: $base"
        return 0
      fi
      remove_image "$base"
    fi
  }

  pull_base_image() {
    local file="$1"
    local base
    base="$(base_image_from_file "$file")"
    if [ -n "$base" ]; then
      base="$(image_family_preferred "$base")"
    fi
    if [ -n "$base" ]; then
      if local_dockerfile_exists_for_image "$base"; then
        echo "Skipping base image pull for local image: $base"
        return 0
      fi
      "$CONTAINER_CMD" image pull "$base"
    fi
  }

  local build_order_lines=""
  local build_seen_lines=""
  local build_visiting_lines=""

  list_has_line() {
    local lines="$1"
    local value="$2"
    [ -n "$value" ] || return 1
    printf '%s\n' "$lines" | grep -Fqx -- "$value"
  }

  resolve_build_dependencies() {
    local name="$1"
    local file_path
    local file_name
    local base
    local base_file

    if list_has_line "$build_seen_lines" "$name"; then
      return 0
    fi
    if list_has_line "$build_visiting_lines" "$name"; then
      die "Cyclic local image dependency detected while resolving $name"
    fi
    if ! is_local_agent_build_image "$name"; then
      die "Unknown image: $name"
    fi

    file_path="$(dockerfile_path_for_image "$name" || true)"
    if [ -z "$file_path" ] || [ ! -f "$file_path" ]; then
      file_name="$(dockerfile_name_for_image "$name" || true)"
      if [ -n "$file_name" ]; then
        die "Unknown image: $name (expected local Dockerfile: $file_name)"
      fi
      die "Unknown image: $name"
    fi

    build_visiting_lines="${build_visiting_lines}${name}"$'\n'
    base="$(base_image_from_file "$file_path")"
    if [ -n "$base" ]; then
      base="$(image_family_preferred "$base")"
    fi
    if [ -n "$base" ] && is_local_agent_build_image "$base"; then
      if ! local_dockerfile_exists_for_image "$base"; then
        base_file="$(dockerfile_name_for_image "$base" || true)"
        die "Missing local base image definition for $name: expected $base_file because $file_path uses FROM $base"
      fi
      resolve_build_dependencies "$base"
    fi
    build_visiting_lines="$(printf '%s\n' "$build_visiting_lines" | grep -Fvx -- "$name" || true)"
    build_seen_lines="${build_seen_lines}${name}"$'\n'
    build_order_lines="${build_order_lines}${name}"$'\n'
  }

  build_one() {
    local name="$1"
    local file
    local file_path
    local context="$SCRIPT_DIR"
    local -a build_args=()
    name="$(image_family_preferred "$name")"
    local versioned_name="${name}:${build_stamp}"
    local base=""
    file="$(dockerfile_name_for_image "$name")"
    file_path="$SCRIPT_DIR/$file"
    if [ "$rebuild" -eq 0 ] && [ "$default_runtime_overridden" -eq 0 ] && [ "$runtimes_overridden" -eq 0 ] && image_exists "$name"; then
      if [ "$snapshot" -eq 1 ]; then
        echo "Snapshotting existing image tags: $name, $versioned_name"
        "$CONTAINER_CMD" image tag "$name" "$versioned_name"
        return 0
      fi
      echo "Image already exists: $name (use --rebuild to rebuild)"
      return 0
    fi
    if [ "$refresh_base" -eq 1 ]; then
      refresh_base_image "$file_path"
    fi
    if [ "$pull_base" -eq 1 ]; then
      pull_base_image "$file_path"
    fi
    if [ "$rebuild" -eq 1 ] && [ "$pull_base" -eq 0 ] && [ "$refresh_base" -eq 0 ]; then
      base="$(base_image_from_file "$file_path")"
      if [ -n "$base" ]; then
        base="$(image_family_preferred "$base")"
      fi
      if [ -n "$base" ] && ! local_dockerfile_exists_for_image "$base"; then
        echo "Note: --rebuild disables layer cache but does not refresh remote base image tags."
        echo "      Use --pull-base (preferred) or --refresh-base to update $base."
      fi
    fi
    echo "Building image tags: $name, $versioned_name"
    build_args=(build -t "$name" -f "$file_path" --build-arg "AGENT_RUNTIMES=$runtimes_csv" --build-arg "AGENT_DEFAULT_RUNTIME=$default_runtime")
    if [ -n "$no_cache" ]; then
      build_args+=("$no_cache")
      build_args+=("$context")
    else
      build_args+=("$context")
    fi
    "$CONTAINER_CMD" "${build_args[@]}"
    "$CONTAINER_CMD" image tag "$name" "$versioned_name"
  }

  if [ -n "$image" ]; then
    resolve_build_dependencies "$image"
  else
    while IFS= read -r local_image; do
      [ -z "$local_image" ] && continue
      resolve_build_dependencies "$local_image"
    done <<< "$(list_local_build_images)"
  fi

  if [ -z "$build_order_lines" ]; then
    die "No local DockerFiles found for build"
  fi

  while IFS= read -r build_image; do
    [ -z "$build_image" ] && continue
    build_one "$build_image"
  done <<< "$build_order_lines"

  stop_buildkit_container
}

run_auth_flow() {
  local image="$1"
  local auth_name="$2"
  local runtime="${3:-$DEFAULT_RUNTIME}"
  local created=0
  local runtime_info=""
  local auth_format=""
  local auth_blob_before=""
  local auth_blob_after=""

  cleanup_auth_container() {
    if [ "$created" -eq 1 ] && container_exists "$auth_name"; then
      "$CONTAINER_CMD" stop "$auth_name" >/dev/null 2>&1 || true
      "$CONTAINER_CMD" rm "$auth_name" >/dev/null 2>&1 || true
    fi
  }

  cleanup_auth_container_on_signal() {
    cleanup_auth_container
    trap - EXIT INT TERM HUP
    exit 130
  }

  trap cleanup_auth_container EXIT
  trap cleanup_auth_container_on_signal INT TERM HUP

  [ -x "$KEYCHAIN_SCRIPT" ] || die "Missing $KEYCHAIN_SCRIPT"

  if container_exists "$auth_name"; then
    die "Auth container already exists: $auth_name (remove it and retry)"
  fi

  local -a auth_create_cmd=("$CONTAINER_CMD" create -t)
  if [ "$runtime" = "claude" ]; then
    auth_create_cmd+=(-m "$CLAUDE_MIN_INSTALL_MEM")
  fi
  auth_create_cmd+=(
    --name "$auth_name"
    "$image" sh -c 'sleep infinity'
  )
  "${auth_create_cmd[@]}" >/dev/null
  created=1

  "$CONTAINER_CMD" start "$auth_name" >/dev/null
  refresh_container_file "$auth_name" "$SCRIPT_DIR/agent.sh" "/usr/local/bin/agent.sh" "root:root" "755"
  refresh_container_file "$auth_name" "$SCRIPT_DIR/config.toml" "/etc/agentctl/config.toml" "root:root" "644"
  refresh_container_file "$auth_name" "$SCRIPT_DIR/local_models.json" "/etc/agentctl/local_models.json" "root:root" "644"
  refresh_container_file "$auth_name" "$SCRIPT_DIR/config.toml" "/etc/codexctl/config.toml" "root:root" "644"
  refresh_container_file "$auth_name" "$SCRIPT_DIR/local_models.json" "/etc/codexctl/local_models.json" "root:root" "644"
  refresh_container_file "$auth_name" "$SCRIPT_DIR/claude-settings.json" "/etc/claudectl/settings.json" "root:root" "644"
  refresh_container_file "$auth_name" "$SCRIPT_DIR/agentctl-path.sh" "/etc/profile.d/agentctl-path.sh" "root:root" "644"
  refresh_container_tree "$auth_name" "$SCRIPT_DIR/runtimes" "/usr/local/lib/agentctl/runtimes" "root:root" "644" "755"
  refresh_container_tree "$auth_name" "$SCRIPT_DIR/runtimes.d" "/etc/agentctl/runtimes.d" "root:root" "644" "755"
  refresh_container_tree "$auth_name" "$SCRIPT_DIR/features" "/usr/local/lib/agentctl/features" "root:root" "644" "755"
  refresh_container_tree "$auth_name" "$SCRIPT_DIR/features.d" "/etc/agentctl/features.d" "root:root" "644" "755"
  runtime_info="$("$CONTAINER_CMD" exec "$auth_name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh runtime info "$runtime")" || die "Failed to inspect runtime auth contract: $runtime"
  if ! printf '%s' "$runtime_info" | jq -e '.installed == true' >/dev/null; then
    if printf '%s' "$runtime_info" | jq -e '(.capabilities.install // false) == true' >/dev/null; then
      echo "Installing runtime in auth container: $runtime" >&2
      "$CONTAINER_CMD" exec -it "$auth_name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh runtime install "$runtime" || die "Failed to install runtime for auth flow: $runtime"
      runtime_info="$("$CONTAINER_CMD" exec "$auth_name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh runtime info "$runtime")" || die "Failed to inspect installed runtime auth contract: $runtime"
    else
      die "Runtime is not installed in auth container and cannot be installed automatically: $runtime"
    fi
  fi
  if ! printf '%s' "$runtime_info" | jq -e '.installed == true and (.capabilities.auth_login // false) and (.capabilities.auth_read // false)' >/dev/null; then
    die "Runtime does not support host-managed auth flow yet: $runtime"
  fi
  auth_format="$(printf '%s' "$runtime_info" | jq -er '.auth_formats[0] // empty')" || die "Runtime does not expose a host-storable auth format: $runtime"
  auth_blob_before="$("$CONTAINER_CMD" exec "$auth_name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh auth read "$runtime" "$auth_format" 2>/dev/null || true)"
  "$CONTAINER_CMD" exec -it "$auth_name" bash -lc "exec bash /usr/local/bin/agent.sh auth login $runtime"
  auth_blob_after="$("$CONTAINER_CMD" exec "$auth_name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh auth read "$runtime" "$auth_format")" || die "Runtime login did not produce readable auth state: $runtime"
  if [ -z "$auth_blob_after" ]; then
    die "Runtime login returned empty auth state: $runtime"
  fi
  if [ "$auth_blob_after" = "$auth_blob_before" ]; then
    die "Runtime auth state did not change; leaving Keychain untouched: $runtime"
  fi
  printf '%s' "$auth_blob_after" | write_keychain_auth_blob "$runtime" "$auth_format"
  "$CONTAINER_CMD" stop "$auth_name" >/dev/null
  "$CONTAINER_CMD" rm "$auth_name" >/dev/null
  created=0
  trap - EXIT INT TERM HUP
}

backup_codex_config() {
