warn_upgrade_package_loss() {
  local name="$1"
  local current_image="$2"
  local target_image="$3"
  local current_manifest=""
  local source_manifest=""
  local stored_manifest=""
  local target_manifest=""
  local current_package_manager=""
  local source_package_manager=""
  local target_package_manager=""
  local current_packages_json='[]'
  local source_packages_json='[]'
  local target_packages_json='[]'
  local added_packages_json='[]'
  local lost_packages_json='[]'
  local lost_count=""

  if ! current_manifest="$(container_system_manifest_json "$name")"; then
    warn "Unable to inspect installed OS packages in $name before upgrade"
    return 0
  fi
  current_package_manager="$(manifest_package_manager "$current_manifest")"
  current_packages_json="$(manifest_packages_json "$current_manifest")"
  if [ "$current_package_manager" = "unknown" ]; then
    warn "Unable to determine the package manager in $name before upgrade"
    return 0
  fi

  if ! target_manifest="$(image_system_manifest_json "$target_image" target)"; then
    warn "Unable to inspect OS packages in target image $target_image before upgrade"
    return 0
  fi
  target_package_manager="$(manifest_package_manager "$target_manifest")"
  target_packages_json="$(manifest_packages_json "$target_manifest")"

  if stored_manifest="$(container_baseline_manifest_json "$name")"; then
    source_manifest="$stored_manifest"
  elif [ "$current_image" = "$target_image" ]; then
    source_manifest="$target_manifest"
  elif image_exists "$current_image"; then
    if ! source_manifest="$(image_system_manifest_json "$current_image" source)"; then
      warn "Unable to inspect OS packages in current image $current_image; package warning may include image-provided packages"
      added_packages_json="$current_packages_json"
    fi
  else
    warn "Current image $current_image is not available locally; package warning may include image-provided packages"
    added_packages_json="$current_packages_json"
  fi

  if [ -n "$source_manifest" ]; then
    source_package_manager="$(manifest_package_manager "$source_manifest")"
    source_packages_json="$(manifest_packages_json "$source_manifest")"
    if [ "$source_package_manager" = "$current_package_manager" ]; then
      added_packages_json="$(json_string_array_difference "$current_packages_json" "$source_packages_json")"
    else
      warn "Current container package manager differs from its image baseline; package warning may include image-provided packages"
      added_packages_json="$current_packages_json"
    fi
  fi

  if [ "$current_package_manager" = "$target_package_manager" ]; then
    lost_packages_json="$(json_string_array_difference "$added_packages_json" "$target_packages_json")"
  else
    lost_packages_json="$added_packages_json"
  fi

  lost_count="$(printf '%s' "$lost_packages_json" | jq -r 'length' 2>/dev/null || printf '0\n')"
  [ "$lost_count" -gt 0 ] || return 0

  if [ "$current_package_manager" = "$target_package_manager" ]; then
    warn "Upgrade will remove $lost_count extra $current_package_manager package(s) not present in $target_image:"
  else
    warn "Upgrade changes package manager from $current_package_manager to $target_package_manager; reinstall these extra $current_package_manager packages manually if still needed:"
  fi
  printf '%s' "$lost_packages_json" | jq -r '.[] | "  - " + .' >&2
}

print_upgrade_dry_run_summary() {
  local name="$1"
  local target_name="$2"
  local current_image="$3"
  local target_image="$4"
  local current_workdir="$5"
  local target_workdir="$6"
  local mount_mode="$7"
  local current_cpu="$8"
  local target_cpu="$9"
  local current_mem="${10}"
  local target_mem="${11}"
  local was_running="${12}"
  local backup_mode="${13}"
  local no_backup="${14}"
  local backup_image="${15}"
  local overwrite_config="${16}"
  local copy_mode="${17:-0}"
  local state_label=""
  local mount_label=""
  local config_label=""
  local backup_label=""
  local overwrite_label="no"
  local source_image_display=""
  local target_image_display=""
  local current_mem_display=""
  local target_mem_display=""

  if [ "$was_running" -eq 1 ]; then
    state_label="running"
  else
    state_label="stopped"
  fi

  if [ "$mount_mode" = "ro" ]; then
    mount_label="read-only"
  else
    mount_label="read-write"
  fi

  case "$backup_mode" in
    export)
      config_label="export existing container filesystem and recover user state from it"
      ;;
    start)
      config_label="start the stopped source container, back up user state, then stop it again"
      ;;
    running)
      config_label="back up user state from the running source container"
      ;;
    *)
      config_label="back up user state"
      ;;
  esac

  if [ "$copy_mode" -eq 1 ]; then
    backup_label="not needed (source preserved)"
  elif [ "$no_backup" -eq 1 ]; then
    backup_label="skipped (--no-backup)"
  else
    backup_label="$backup_image"
  fi

  if [ "$overwrite_config" -eq 1 ]; then
    overwrite_label="yes"
  fi

  source_image_display="$(display_upgrade_image_ref "$current_image")"
  target_image_display="$(display_upgrade_image_ref "$target_image")"
  current_mem_display="$(display_upgrade_memory_limit "$current_mem")"
  target_mem_display="$(display_upgrade_memory_limit "$target_mem")"

  echo "Dry run: upgrade plan for $name -> $target_name" >&2
  echo "  Source image: $source_image_display" >&2
  echo "  Target image: $target_image_display" >&2
  echo "  Source workdir: $current_workdir" >&2
  echo "  Target workdir: $target_workdir" >&2
  echo "  Mount mode: $mount_label" >&2
  echo "  CPU: ${current_cpu:-unlimited} -> ${target_cpu:-unlimited}" >&2
  echo "  Memory: $current_mem_display -> $target_mem_display" >&2
  echo "  Current state: $state_label" >&2
  echo "  Config backup: $config_label" >&2
  echo "  Backup image: $backup_label" >&2
  echo "  Overwrite config: $overwrite_label" >&2
  if [ "$copy_mode" -eq 1 ]; then
    echo "  Actions: keep $name and create $target_name as a copy" >&2
  elif [ "$name" = "$target_name" ]; then
    echo "  Actions: remove $name and recreate it in place" >&2
  else
    echo "  Actions: remove $name and recreate it as $target_name" >&2
  fi
  echo "Dry run complete: no container changes applied" >&2
}

display_upgrade_image_ref() {
  local image_ref="$1"

  if [ -z "$image_ref" ]; then
    printf 'unknown\n'
    return 0
  fi
  if [[ "$image_ref" == *:latest ]]; then
    printf '%s\n' "${image_ref%:latest}"
    return 0
  fi
  printf '%s\n' "$image_ref"
}

display_upgrade_memory_limit() {
  local value="$1"
  local unit=""
  local divisor=1

  if [ -z "$value" ] || [ "$value" = "0" ]; then
    printf 'unlimited\n'
    return 0
  fi
  if [[ ! "$value" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$value"
    return 0
  fi

  if [ $((value % 1073741824)) -eq 0 ]; then
    unit="G"
    divisor=1073741824
  elif [ $((value % 1048576)) -eq 0 ]; then
    unit="M"
    divisor=1048576
  elif [ $((value % 1024)) -eq 0 ]; then
    unit="K"
    divisor=1024
  fi

  if [ -n "$unit" ]; then
    printf '%s%s\n' "$((value / divisor))" "$unit"
    return 0
  fi
  printf '%s\n' "$value"
}

run_container() {
  local name="$1"
  local image="$2"
  local temp="$3"
  local shell="$4"
  local cpu="$5"
  local mem="$6"
  local read_only="$7"
  local workdir="$8"
  local pre_exec="$9"
  local post_exec="${10}"
  local reset_config="${11}"
  shift 11
  local cmd=("$@")
  local exit_code=0
  local started=0
  local already_running=0
  local created=0
  local actual_name="$name"

  # Execute command inside the container and preserve the exit code.
  run_exec() {
    if [ "$shell" -eq 1 ]; then
      if ! "$CONTAINER_CMD" exec -it "$actual_name" "${SETPRIV_ARGS[@]}" "$DEFAULT_LOGIN_SHELL" "-l"; then
        exit_code=$?
      fi
    else
      if ! "$CONTAINER_CMD" exec -it "$actual_name" "${SETPRIV_ARGS[@]}" "${cmd[@]}"; then
        exit_code=$?
      fi
    fi
  }

  # Lifecycle: create if missing, start if needed, pre_exec, exec, stop, remove if temp.
  if [ -n "$actual_name" ] && container_exists "$actual_name"; then
    validate_mount_mode "$actual_name" "$read_only"
  fi
  if [ -n "$actual_name" ] && container_running "$actual_name"; then
    already_running=1
  else
    if [ -n "$actual_name" ] && [ "$temp" -eq 1 ] && container_exists "$actual_name"; then
      die "Container already exists: $actual_name (omit --temp or remove it)"
    fi
    if [ "$temp" -eq 0 ] && [ -z "$actual_name" ]; then
      die "Missing container name"
    fi

    if [ -z "$actual_name" ] || ! container_exists "$actual_name"; then
      echo "Creating container..." >&2
      local create_cmd=("$CONTAINER_CMD" create -t)
      if [ -n "$cpu" ]; then
        create_cmd+=(-c "$cpu")
      fi
      if [ -n "$mem" ]; then
        create_cmd+=(-m "$mem")
      fi
      if [ -n "$actual_name" ]; then
        create_cmd+=(--name "$actual_name")
      fi
      local mount_opts="type=bind,src=$workdir,dst=/workdir"
      if [ "$read_only" -eq 1 ]; then
        mount_opts="${mount_opts},readonly"
      fi
      create_cmd+=(
        --mount "$mount_opts"
        "$image" sh -c 'sleep infinity'
      )
      if [ -z "$actual_name" ]; then
        actual_name="$("${create_cmd[@]}")"
        [ -n "$actual_name" ] || die "Failed to create temporary container"
      else
        "${create_cmd[@]}"
      fi
      created=1
    fi

    echo "Starting container: $actual_name" >&2
    "$CONTAINER_CMD" start "$actual_name"
    started=1
  fi

  if [ "$created" -eq 1 ]; then
    persist_container_system_manifest_baseline_from_image "$actual_name" "$image"
  fi

  if [ "$reset_config" -eq 1 ]; then
    reset_runtime_config_in_container "$actual_name" codex
  fi
  if [ -n "$pre_exec" ]; then
    "$pre_exec" "$actual_name"
  fi
  run_exec
  if [ -n "$post_exec" ]; then
    if ! "$post_exec" "$actual_name"; then
      warn "post-run step failed for $actual_name"
    fi
  fi
  if [ "$already_running" -eq 1 ]; then
    return "$exit_code"
  fi
  if [ "$started" -eq 1 ]; then
    echo "Stopping container: $actual_name" >&2
    "$CONTAINER_CMD" stop "$actual_name" >/dev/null 2>&1
  fi
  if [ "$temp" -eq 1 ]; then
    echo "Removing container: $actual_name" >&2
    "$CONTAINER_CMD" rm "$actual_name" >/dev/null 2>&1
  fi
  return "$exit_code"
}

run_mode() {
  local name="$1"
  local image="$2"
  local temp="$3"
  local shell="$4"
  local online="$5"
  local auth="$6"
  local update="$7"
  local cpu="$8"
  local mem="$9"
  local read_only="${10}"
  local workdir="${11}"
  local reset_config="${12}"
  local runtime_config_json="${13}"
  local model_override="${14}"
  shift 14
  local -a cmd_override=("$@")
  local pre_exec=""
  local post_exec=""
  local runtime_mode="local"
  local cmd=("$DEFAULT_LOGIN_SHELL" "-lc" "AGENTCTL_RUN_MODE=\$1 AGENTCTL_RUNTIME_CONFIG_JSON=\$2 AGENTCTL_MODEL_OVERRIDE=\$3 exec bash /usr/local/bin/agent.sh run" sh "$runtime_mode" "$runtime_config_json" "$model_override")

  if [ "$online" -eq 1 ]; then
    runtime_mode="online"
    post_exec="run_post_exec"
    cmd=("$DEFAULT_LOGIN_SHELL" "-lc" "AGENTCTL_RUN_MODE=\$1 AGENTCTL_RUNTIME_CONFIG_JSON=\$2 AGENTCTL_MODEL_OVERRIDE=\$3 exec bash /usr/local/bin/agent.sh run" sh "$runtime_mode" "$runtime_config_json" "$model_override")
  fi
  if [ "$RUN_UPDATE_CODEX" -eq 1 ] || [ -n "$RUN_SELECTED_RUNTIME" ] || [ "$RUN_SYNC_RUNTIME_AUTH" -eq 1 ] || [ "$RUN_LOCAL_MODEL_PREFLIGHT" -eq 1 ]; then
    pre_exec="run_pre_exec"
  fi

  if [ "${#cmd_override[@]}" -gt 0 ]; then
    cmd=("${cmd_override[@]}")
    shell=0
  fi

  run_container "$name" "$image" "$temp" "$shell" "$cpu" "$mem" "$read_only" "$workdir" "$pre_exec" "$post_exec" "$reset_config" "${cmd[@]}"
}

RUN_SELECTED_RUNTIME=""
RUN_INSTALL_RUNTIME=0
RUN_SYNC_RUNTIME_AUTH=0
RUN_SYNC_POST_RUNTIME_AUTH=0
RUN_FORCE_RUNTIME_AUTH=0
RUN_LOCAL_MODEL_PREFLIGHT=0
RUN_UPDATE_CODEX=0
RUN_EFFECTIVE_MODE="local"
RUN_REQUESTED_IMAGE=""
RUN_RUNTIME_CONFIG_JSON='{}'

run_post_exec() {
  local name="$1"
  local effective_runtime=""

  if [ "$RUN_SYNC_POST_RUNTIME_AUTH" -eq 0 ]; then
    return 0
  fi

  effective_runtime="$RUN_SELECTED_RUNTIME"
  if [ -z "$effective_runtime" ]; then
    effective_runtime="$(run_agent_sh_in_container "$name" preferred get 2>/dev/null || true)"
  fi
  [ -n "$effective_runtime" ] || return 0
  sync_runtime_auth_from_container_if_available "$name" "$effective_runtime"
}

run_pre_exec() {
  local name="$1"
  local effective_runtime=""
  local auth_image=""
  local runtime_info=""
  local auth_format=""
  local keychain_info=""
  local keychain_token=""
  local keychain_refresh=""

  if [ "$RUN_UPDATE_CODEX" -eq 1 ]; then
    update_codex_pre_exec "$name"
  fi

  if [ -n "$RUN_SELECTED_RUNTIME" ]; then
    if [ "$RUN_INSTALL_RUNTIME" -eq 1 ]; then
      run_agent_sh_in_container_root "$name" runtime install "$RUN_SELECTED_RUNTIME"
    fi
    run_agent_sh_in_container "$name" preferred set "$RUN_SELECTED_RUNTIME"
  fi

  if [ "$RUN_SYNC_RUNTIME_AUTH" -eq 1 ] || [ "$RUN_LOCAL_MODEL_PREFLIGHT" -eq 1 ] || [ "$RUN_SYNC_POST_RUNTIME_AUTH" -eq 1 ]; then
    effective_runtime="$RUN_SELECTED_RUNTIME"
    if [ -z "$effective_runtime" ]; then
      effective_runtime="$(run_agent_sh_in_container "$name" preferred get 2>/dev/null || true)"
    fi
  fi

  if [ "$RUN_SYNC_RUNTIME_AUTH" -eq 1 ] && [ -n "$effective_runtime" ]; then
    runtime_info="$(runtime_info_in_container "$name" "$effective_runtime" 2>/dev/null || true)"
    if [ -n "$runtime_info" ] && printf '%s' "$runtime_info" | jq -e '.installed == true and (.capabilities.auth_login // false) and (.capabilities.auth_read // false) and (.capabilities.auth_write // false)' >/dev/null 2>&1; then
      auth_format="$(printf '%s' "$runtime_info" | jq -er '.auth_formats[0] // empty' 2>/dev/null || true)"
      if [ -n "$auth_format" ]; then
        keychain_info="$(keychain_auth_info "$effective_runtime" "$auth_format" 2>/dev/null || true)"
        IFS=$'\t' read -r keychain_token keychain_refresh <<<"$keychain_info"
        if [ "$RUN_FORCE_RUNTIME_AUTH" -eq 1 ] || [ -z "$keychain_token" ]; then
          auth_image="$(resolve_auth_image_for_container "$name" "$RUN_REQUESTED_IMAGE")"
          run_auth_flow "$auth_image" "$(default_name "$AUTH_NAME_PREFIX")" "$effective_runtime"
        fi
        sync_runtime_auth_to_container "$name" "$effective_runtime" "$auth_format" "Missing runtime auth in Keychain. Run: ${CLI_NAME} auth --runtime $effective_runtime"
      fi
    fi
  fi

  if [ "$RUN_LOCAL_MODEL_PREFLIGHT" -eq 1 ]; then
    if [ -z "$effective_runtime" ]; then
      effective_runtime="$DEFAULT_RUNTIME"
    fi
    local_runtime_preflight "$name" "$effective_runtime" "$RUN_RUNTIME_CONFIG_JSON" strict
  fi
}

codex_local_model_preflight_info() {
  local name="$1"
  local profile="$2"

  "$CONTAINER_CMD" exec -i "$name" "${SETPRIV_ARGS[@]}" sh -s -- "$profile" <<'SH'
profile="${1:-gpt-oss}"
config_file=""
provider=""
base_url=""
configured_api_url=""
configured_ok=0
gateway=""
gateway_api_url=""
gateway_ok=0

for candidate in /home/coder/.codex/config.toml /etc/codexctl/config.toml; do
  if [ -f "$candidate" ]; then
    config_file="$candidate"
    break
  fi
done

if [ -n "$config_file" ]; then
  provider="$(awk -v profile="$profile" '
    /^\[profiles\.[^]]+\][[:space:]]*$/ {
      current=$0
      sub(/^\[profiles\./, "", current)
      sub(/\][[:space:]]*$/, "", current)
      in_profile=(current == profile)
      next
    }
    /^\[[^]]+\][[:space:]]*$/ {
      in_profile=0
    }
    in_profile && /^[[:space:]]*model_provider[[:space:]]*=/ {
      line=$0
      sub(/^[^"]*"/, "", line)
      sub(/".*$/, "", line)
      print line
      exit
    }
  ' "$config_file")"
  if [ -n "$provider" ]; then
    base_url="$(awk -v provider="$provider" '
      /^\[model_providers\.[^]]+\][[:space:]]*$/ {
        current=$0
        sub(/^\[model_providers\./, "", current)
        sub(/\][[:space:]]*$/, "", current)
        in_provider=(current == provider)
        next
      }
      /^\[[^]]+\][[:space:]]*$/ {
        in_provider=0
      }
      in_provider && /^[[:space:]]*base_url[[:space:]]*=/ {
        line=$0
        sub(/^[^"]*"/, "", line)
        sub(/".*$/, "", line)
        print line
        exit
      }
    ' "$config_file")"
  fi
  if [ -z "$base_url" ]; then
    base_url="$(awk '
      /^[[:space:]]*base_url[[:space:]]*=/ {
        line=$0
        sub(/^[^"]*"/, "", line)
        sub(/".*$/, "", line)
        print line
        exit
      }
    ' "$config_file")"
  fi
fi

if [ -n "$base_url" ]; then
  case "$base_url" in
    http://*|https://*)
      configured_api_url="$(printf '%s\n' "$base_url" | awk -F/ 'NF >= 3 { print $1 "//" $3 "/api/version"; exit }')"
      if [ -n "$configured_api_url" ] && curl -fsS --max-time 3 "$configured_api_url" >/dev/null 2>&1; then
        configured_ok=1
      fi
      ;;
  esac
fi

gateway="$(awk '
  function hex2dec(hex,   i, c, n, v) {
    n = 0
    hex = toupper(hex)
    for (i = 1; i <= length(hex); i++) {
      c = substr(hex, i, 1)
      v = index("0123456789ABCDEF", c) - 1
      if (v < 0) {
        return ""
      }
      n = (n * 16) + v
    }
    return n
  }
  $2 == "00000000" && length($3) == 8 {
    printf "%s.%s.%s.%s\n",
      hex2dec(substr($3, 7, 2)),
      hex2dec(substr($3, 5, 2)),
      hex2dec(substr($3, 3, 2)),
      hex2dec(substr($3, 1, 2))
    exit
  }
' /proc/net/route 2>/dev/null || true)"
if [ -n "$gateway" ]; then
  gateway_api_url="http://${gateway}:11434/api/version"
  if curl -fsS --max-time 3 "$gateway_api_url" >/dev/null 2>&1; then
    gateway_ok=1
  fi
fi

printf 'config_file=%s\n' "$config_file"
printf 'base_url=%s\n' "$base_url"
printf 'configured_api_url=%s\n' "$configured_api_url"
printf 'configured_ok=%s\n' "$configured_ok"
printf 'gateway=%s\n' "$gateway"
printf 'gateway_api_url=%s\n' "$gateway_api_url"
printf 'gateway_ok=%s\n' "$gateway_ok"
SH
}

