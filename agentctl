upgrade_cmd() {
  local name=""
  local new_name=""
  local copy_mode=0
  local target_name=""
  local image=""
  local workdir_override=""
  local cpu=""
  local mem=""
  local backup_image=""
  local no_backup=0
  local dry_run=0
  local overwrite_config=0
  local current_image=""
  local current_workdir=""
  local workdir=""
  local mount_mode=""
  local current_cpu=""
  local current_mem=""
  local read_only=0
  local was_running=0
  local started_for_backup=0
  local used_export_for_config_backup=0
  local backup_mode=""
  local source_supports_state_contract=""
  local added_runtimes_json='[]'
  local added_features_json='[]'
  local inspect_info=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --new-name) new_name="$2"; shift 2 ;;
      --copy) copy_mode=1; shift ;;
      --image) image="$2"; shift 2 ;;
      --workdir) workdir_override="$2"; shift 2 ;;
      --cpu) cpu="$2"; shift 2 ;;
      --mem) mem="$2"; shift 2 ;;
      --backup-image) backup_image="$2"; shift 2 ;;
      --no-backup) no_backup=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      --overwrite-config) overwrite_config=1; shift ;;
      --help) usage_upgrade; return 0 ;;
      *) die "Unknown option for upgrade: $1" ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi
  if [ -n "$new_name" ]; then
    target_name="$new_name"
  else
    target_name="$name"
  fi
  if [ "$copy_mode" -eq 1 ] && [ -z "$new_name" ]; then
    die "Copy mode requires --new-name."
  fi
  if [ "$copy_mode" -eq 1 ] && [ "$target_name" = "$name" ]; then
    die "Copy mode requires a target name different from the source container."
  fi
  if [ "$no_backup" -eq 1 ] && [ -n "$backup_image" ]; then
    die "Cannot combine --no-backup with --backup-image"
  fi
  if [ "$copy_mode" -eq 1 ] && [ -n "$backup_image" ]; then
    die "Cannot combine --copy with --backup-image."
  fi
  if [ "$copy_mode" -eq 0 ] && [ "$no_backup" -eq 0 ]; then
    require_container_backup_support
  fi
  if ! container_exists "$name"; then
    die "Container not found: $name"
  fi
  if [ "$target_name" != "$name" ] && container_exists "$target_name"; then
    die "Target container name already exists: $target_name"
  fi

  inspect_info="$("$CONTAINER_CMD" inspect "$name" 2>/dev/null | container_upgrade_info)"
  IFS=$'\t' read -r current_image current_workdir mount_mode current_cpu current_mem <<<"$inspect_info"
  [ -n "$current_image" ] || die "Unable to determine image for $name"
  [ -n "$current_workdir" ] || die "Unable to determine /workdir mount source for $name"

  if [ "$mount_mode" = "ro" ]; then
    read_only=1
  elif [ "$mount_mode" != "rw" ]; then
    die "Unable to determine mount mode for $name"
  fi

  [ -n "$image" ] || image="$current_image"
  image="$(image_ref_for_runtime "$image")"
  warn_legacy_compat_image_usage "$image"
  if [ -n "$workdir_override" ]; then
    [ -d "$workdir_override" ] || die "Workdir not found: $workdir_override"
    workdir="$(CDPATH= cd -- "$workdir_override" && pwd)"
  else
    workdir="$current_workdir"
  fi
  [ -n "$cpu" ] || cpu="$current_cpu"
  [ -n "$mem" ] || mem="$current_mem"
  image_exists "$image" || die "Image not found: $image"
  if [ -z "$workdir_override" ]; then
    [ -e "$workdir" ] || die "Preserved /workdir source does not exist: $workdir"
    [ -d "$workdir" ] || die "Preserved /workdir source is not a directory: $workdir"
  fi
  if container_running "$name"; then
    was_running=1
  fi
  if [ "$was_running" -eq 0 ] && [ -n "$workdir_override" ] && [ ! -e "$current_workdir" ]; then
    warn "Skipping package-loss warning because original /workdir source does not exist and $name is stopped"
    backup_mode="export"
  else
    warn_upgrade_package_loss "$name" "$current_image" "$image"
    added_runtimes_json="$(upgrade_added_runtimes_json "$name" "$current_image" "$image" 2>/dev/null || printf '[]\n')"
    added_features_json="$(upgrade_added_features_json "$name" "$current_image" "$image" 2>/dev/null || printf '[]\n')"
    if container_supports_state_contract "$name"; then
      source_supports_state_contract=1
    else
      source_supports_state_contract=0
    fi
    if [ "$was_running" -eq 0 ]; then
      backup_mode="start"
    else
      backup_mode="running"
    fi
  fi
  if [ "$copy_mode" -eq 0 ] && [ "$no_backup" -eq 1 ] && [ "${source_supports_state_contract:-}" = "0" ]; then
    die "Legacy source containers require a backup image for upgrade safety. Re-run without --no-backup."
  fi
  if [ "$copy_mode" -eq 0 ] && [ "$no_backup" -eq 0 ] && [ -z "$backup_image" ]; then
    backup_image="$(sanitize_image_name "${target_name}-backup-$(date -u +%Y%m%d%H%M%S)")"
  fi
  if [ "$dry_run" -eq 1 ]; then
    print_upgrade_dry_run_summary \
      "$name" "$target_name" "$current_image" "$image" "$current_workdir" "$workdir" \
      "$mount_mode" "$current_cpu" "$cpu" "$current_mem" "$mem" "$was_running" \
      "$backup_mode" "$no_backup" "$backup_image" "$overwrite_config" "$copy_mode"
    return 0
  fi

  local backup_dir
  local state_backup_file
  local export_file
  local backup_root
  local backup_dockerfile
  local export_config_root
  backup_dir="$(mktemp -d)"
  state_backup_file="$backup_dir/container-state.tar"
  export_file="$backup_dir/codex-export.tar"
  backup_root="$backup_dir/rootfs"
  backup_dockerfile="$backup_dir/Dockerfile.backup"
  export_config_root="$backup_dir/export-config"
  trap 'cleanup_temp_dir "$backup_dir"' RETURN

  if [ "$was_running" -eq 0 ] && [ -n "$workdir_override" ] && [ ! -e "$current_workdir" ]; then
    echo "Exporting container filesystem for state backup: $name" >&2
    "$CONTAINER_CMD" export "$name" --output "$export_file"
    extract_export_root "$export_file" "$export_config_root"
    if export_root_supports_state_contract "$export_config_root"; then
      source_supports_state_contract=1
    else
      source_supports_state_contract=0
    fi
    if [ "$copy_mode" -eq 0 ] && [ "$no_backup" -eq 1 ] && [ "$source_supports_state_contract" -eq 0 ]; then
      die "Legacy source containers require a backup image for upgrade safety. Re-run without --no-backup."
    fi
    backup_codex_config_from_export "$export_file" "$state_backup_file" "$export_config_root"
    used_export_for_config_backup=1
  elif [ "$was_running" -eq 0 ]; then
    echo "Starting container for state backup: $name" >&2
    "$CONTAINER_CMD" start "$name" >/dev/null
    started_for_backup=1
  fi

  local agents_state=""
  if [ "$used_export_for_config_backup" -eq 1 ]; then
    agents_state="$(codex_agents_state_from_export_root "$export_config_root")"
  else
    agents_state="$(codex_agents_state "$name")"
  fi
  case "$agents_state" in
    symlink|missing) ;;
    file)
      if [ "$overwrite_config" -eq 0 ]; then
        if [ "$started_for_backup" -eq 1 ]; then
          echo "Stopping container: $name" >&2
          "$CONTAINER_CMD" stop "$name" >/dev/null || true
        fi
        die "Container has ~/.codex/AGENTS.md as a regular file. Re-run with --overwrite-config to replace ~/.codex/config.toml and ~/.codex/local_models.json and recreate ~/.codex/AGENTS.md as a symlink to /etc/codexctl/image.md. If no valid AGENTS.md configuration already exists, use ${CLI_NAME} run --name $name --reset-config"
      fi
      echo "Warning: replacing regular ~/.codex/AGENTS.md, ~/.codex/config.toml, and ~/.codex/local_models.json in $name due to --overwrite-config" >&2
      ;;
    other)
      if [ "$overwrite_config" -eq 0 ]; then
        if [ "$started_for_backup" -eq 1 ]; then
          echo "Stopping container: $name" >&2
          "$CONTAINER_CMD" stop "$name" >/dev/null || true
        fi
        die "Container has ~/.codex/AGENTS.md in a non-symlink form. Re-run with --overwrite-config to recreate it as a symlink to /etc/codexctl/image.md. If no valid AGENTS.md configuration already exists, use ${CLI_NAME} run --name $name --reset-config"
      fi
      echo "Warning: replacing non-standard ~/.codex/AGENTS.md in $name due to --overwrite-config" >&2
      ;;
  esac

  if [ "$used_export_for_config_backup" -eq 1 ]; then
    echo "Backing up user state from exported filesystem: $name" >&2
  else
    echo "Backing up user state from $name" >&2
    backup_codex_config "$name" "$state_backup_file"
  fi

  if { [ "$copy_mode" -eq 0 ] && [ "$was_running" -eq 1 ]; } || [ "$started_for_backup" -eq 1 ]; then
    echo "Stopping container: $name" >&2
    "$CONTAINER_CMD" stop "$name" >/dev/null
  fi

  if [ "$copy_mode" -eq 0 ] && [ "$no_backup" -eq 0 ]; then
    if [ "$used_export_for_config_backup" -eq 0 ]; then
      echo "Exporting container state to image: $backup_image" >&2
      "$CONTAINER_CMD" export "$name" --output "$export_file"
    else
      echo "Reusing exported container state for backup image: $backup_image" >&2
    fi
    build_backup_image_from_export "$backup_image" "$name" "$export_file" "$backup_root" "$backup_dockerfile"
  elif [ "$copy_mode" -eq 0 ]; then
    echo "Skipping backup image export for $name" >&2
  fi

  if [ "$copy_mode" -eq 0 ]; then
    echo "Removing container: $name" >&2
    "$CONTAINER_CMD" rm "$name" >/dev/null
    echo "Recreating container: $target_name" >&2
  else
    echo "Creating copy: $target_name" >&2
  fi
  local create_cmd=("$CONTAINER_CMD" create -t)
  if [ -n "$cpu" ]; then
    create_cmd+=(-c "$cpu")
  fi
  if [ -n "$mem" ]; then
    create_cmd+=(-m "$mem")
  fi
  local mount_opts="type=bind,src=$workdir,dst=/workdir"
  if [ "$read_only" -eq 1 ]; then
    mount_opts="${mount_opts},readonly"
  fi
  create_cmd+=(
    --name "$target_name"
    --mount "$mount_opts"
    "$image" sh -c 'sleep infinity'
  )
  "${create_cmd[@]}"

  echo "Starting container: $target_name" >&2
  "$CONTAINER_CMD" start "$target_name" >/dev/null
  persist_container_system_manifest_baseline_from_image "$target_name" "$image"

  reinstall_added_runtimes_and_features "$target_name" "$added_runtimes_json" "$added_features_json"

  echo "Restoring user state into $target_name" >&2
  restore_codex_config "$target_name" "$state_backup_file"
  if [ "$overwrite_config" -eq 1 ]; then
    echo "Overwriting config.toml, local_models.json in ~/.codex/ and recreating ~/.codex/AGENTS.md in $target_name" >&2
    reset_runtime_config_in_container "$target_name" codex
  fi

  if [ "$was_running" -eq 0 ]; then
    echo "Stopping container: $target_name" >&2
    "$CONTAINER_CMD" stop "$target_name" >/dev/null
  fi

  if [ "$copy_mode" -eq 1 ]; then
    echo "Copy complete: $target_name (source preserved)" >&2
  elif [ "$no_backup" -eq 0 ]; then
    echo "Upgrade complete: $target_name (backup image: $backup_image)" >&2
  else
    echo "Upgrade complete: $target_name (backup skipped)" >&2
  fi
  echo >&2
  echo "If no valid AGENTS.md configuration already exists, reset it with: ${CLI_NAME} run --name $target_name --reset-config" >&2
  if [ "$copy_mode" -eq 0 ] && [ "$no_backup" -eq 0 ]; then
    echo "If everything works as expected, remove the backup image with: ${CLI_NAME} images prune --backup --image $backup_image --keep 0" >&2
  fi
}

exec_cmd() {
  local name=""
  local cmd=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --help) usage_exec; return 0 ;;
      --) shift; cmd=("$@"); break ;;
      --*) die "Unknown option for exec: $1" ;;
      *) cmd=("$@"); break ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  if [ "${#cmd[@]}" -eq 0 ]; then
    cmd=("$DEFAULT_LOGIN_SHELL" "-l")
  fi
  if [ "${#cmd[@]}" -eq 1 ]; then
    case "${cmd[0]}" in
      *[[:space:]]*) cmd=("$DEFAULT_LOGIN_SHELL" "-lc" "${cmd[0]}") ;;
    esac
  fi

  if ! container_running "$name"; then
    die "Container not running: $name"
  fi

  "$CONTAINER_CMD" exec -it "$name" "${SETPRIV_ARGS[@]}" "${cmd[@]}"
}

su_exec_cmd() {
  local name=""
  local cmd=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --help) usage_su_exec; return 0 ;;
      --) shift; cmd=("$@"); break ;;
      --*) die "Unknown option for su-exec: $1" ;;
      *) cmd=("$@"); break ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  if [ "${#cmd[@]}" -eq 0 ]; then
    cmd=("$DEFAULT_LOGIN_SHELL" "-l")
  fi
  if [ "${#cmd[@]}" -eq 1 ]; then
    case "${cmd[0]}" in
      *[[:space:]]*) cmd=("$DEFAULT_LOGIN_SHELL" "-lc" "${cmd[0]}") ;;
    esac
  fi

  if ! container_running "$name"; then
    die "Container not running: $name"
  fi

  "$CONTAINER_CMD" exec -u 0 -it "$name" "${cmd[@]}"
}

simple_name_cmd() {
  local action="$1"
  shift
  local name=""
  local force=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --force) force=1; shift ;;
      --help) usage_simple_name; return 0 ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  require_container

  if [ -z "$name" ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX")"
  fi

  case "$action" in
    start) "$CONTAINER_CMD" start "$name" ;;
    stop) "$CONTAINER_CMD" stop "$name" ;;
    restart) "$CONTAINER_CMD" restart "$name" ;;
    rm)
      if [ "$force" -eq 1 ] && container_running "$name"; then
        "$CONTAINER_CMD" stop "$name" >/dev/null
      fi
      "$CONTAINER_CMD" rm "$name"
      ;;
    *) die "Unknown action: $action" ;;
  esac
}

ls_cmd() {
  require_container
  container_list_all | awk '
    NR == 1 { print; next }
    {
      image = $2
      sub(/^.*\//, "", image)
      sub(/[:@].*$/, "", image)
      if (image ~ /^(agent|codex)([[:alnum:]_.-]*|$)/) {
        print
      }
    }
  '
}

cmd="${1:-}"
case "$cmd" in
  build) shift; build_cmd "$@" ;;
  run) shift; run_cmd "$@" ;;
  bootstrap) shift; bootstrap_cmd "$@" ;;
  runtime) shift; runtime_cmd "$@" ;;
  feature) shift; feature_cmd "$@" ;;
  use) shift; use_cmd "$@" ;;
  refresh) shift; refresh_cmd "$@" ;;
  system-manifest) shift; system_manifest_cmd "$@" ;;
  upgrade) shift; upgrade_cmd "$@" ;;
  auth) shift; auth_cmd "$@" ;;
  exec) shift; exec_cmd "$@" ;;
  su-exec) shift; su_exec_cmd "$@" ;;
  start|stop|restart|rm) shift; simple_name_cmd "$cmd" "$@" ;;
  ls) shift; ls_cmd "$@" ;;
  images) shift; images_cmd "$@" ;;
  --help|-h|help|"") usage ;;
  *) die "Unknown command: $cmd" ;;
esac
