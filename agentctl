extract_export_root() {
  local export_file="$1"
  local extract_root="$2"
  local marker_file="$extract_root/.agentctl-export-extracted"

  mkdir -p "$extract_root"
  if [ -f "$marker_file" ]; then
    return 0
  fi
  tar -xf "$export_file" -C "$extract_root"
  : >"$marker_file"
}

backup_codex_config_from_export() {
  local export_file="$1"
  local backup_file="$2"
  local extract_root="$3"
  local home_dir=""
  local -a state_paths=()
  local path=""

  extract_export_root "$export_file" "$extract_root"
  home_dir="$extract_root/home/coder"
  [ -d "$home_dir" ] || return 0

  for path in .codex .config/agentctl .claude .claude.json; do
    if [ -e "$home_dir/$path" ]; then
      state_paths+=("$path")
    fi
  done
  [ "${#state_paths[@]}" -gt 0 ] || return 0

  tar -C "$home_dir" -cf "$backup_file" "${state_paths[@]}"
}

restore_codex_config() {
  local name="$1"
  local backup_file="$2"
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'mkdir -p /home/coder && chown coder:coder /home/coder'
  if [ ! -s "$backup_file" ]; then
    "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'mkdir -p /home/coder/.codex /home/coder/.config/agentctl && chown -R coder:coder /home/coder'
    return 0
  fi
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc '
mkdir -p /home/coder
rm -rf \
  /home/coder/.codex \
  /home/coder/.config/agentctl \
  /home/coder/.claude \
  /home/coder/.claude.json
'
  if target_supports_state_contract "$name"; then
    "$CONTAINER_CMD" exec -i "$name" "${SETPRIV_ARGS[@]}" bash /usr/local/bin/agent.sh state import <"$backup_file"
  else
    "$CONTAINER_CMD" exec -i -u 0 "$name" sh -lc 'cd /home/coder && tar -xf -' <"$backup_file"
  fi
  "$CONTAINER_CMD" exec -u 0 "$name" sh -lc 'chown -R coder:coder /home/coder >/dev/null 2>&1 || true'
