target_runtime_installable() {
  local name="$1"
  local runtime="$2"
  local runtime_info=""

  runtime_info="$(run_agent_sh_in_container "$name" runtime info "$runtime" 2>/dev/null)" || return 1
  printf '%s' "$runtime_info" | jq -e '(.capabilities.install // false) == true' >/dev/null 2>&1
}

target_feature_installable() {
  local name="$1"
  local feature="$2"
  local feature_info=""

  feature_info="$(run_agent_sh_in_container "$name" feature info "$feature" 2>/dev/null)" || return 1
  printf '%s' "$feature_info" | jq -e '(.capabilities.install // false) == true' >/dev/null 2>&1
}

reinstall_added_runtimes_and_features() {
  local name="$1"
  local added_runtimes_json="${2:-[]}"
  local added_features_json="${3:-[]}"
  local runtime=""
  local feature=""

  while IFS= read -r runtime; do
    [ -n "$runtime" ] || continue
    if target_runtime_installable "$name" "$runtime"; then
      echo "Reinstalling added runtime in $name: $runtime" >&2
      run_agent_sh_in_container_root "$name" runtime install "$runtime" || die "Failed to reinstall runtime during upgrade: $runtime"
    else
      warn "Target image cannot automatically reinstall added runtime: $runtime"
    fi
  done < <(printf '%s' "$added_runtimes_json" | jq -r '.[]' 2>/dev/null || true)

  while IFS= read -r feature; do
    [ -n "$feature" ] || continue
    if target_feature_installable "$name" "$feature"; then
      echo "Reinstalling added feature in $name: $feature" >&2
      run_agent_sh_in_container_root "$name" feature install "$feature" || die "Failed to reinstall feature during upgrade: $feature"
    else
      warn "Target image cannot automatically reinstall added feature: $feature"
    fi
  done < <(printf '%s' "$added_features_json" | jq -r '.[]' 2>/dev/null || true)
}

