run_cmd() {
  local name=""
  local image=""
  local runtime=""
  local install_runtime=0
  local online=0
  local auth=0
  local update=0
  local temp=0
  local shell=0
  local reset_config=0
  local runtime_config_json='{}'
  local model_override=""
  local read_only=0
  local cpu=""
  local mem=""
  local workdir=""
  local -a runtime_config_entries=()
  local -a cmd_override=()
  local cmd_override_set=0
  local shell_set=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --image) image="$2"; shift 2 ;;
      --workdir) workdir="$2"; shift 2 ;;
      --runtime) runtime="$2"; shift 2 ;;
      --install-runtime) install_runtime=1; shift ;;
      --model) model_override="$2"; shift 2 ;;
      --online) online=1; shift ;;
      --auth) auth=1; shift ;;
      --reset-config) reset_config=1; shift ;;
      --update) update=1; shift ;;
      --temp) temp=1; shift ;;
      --read-only) read_only=1; shift ;;
      --shell) shell=1; shell_set=1; shift ;;
      -c|--config) runtime_config_entries+=("$2"); shift 2 ;;
      --cmd) shift; cmd_override_set=1; cmd_override=("$@"); break ;;
      --cpu) cpu="$2"; shift 2 ;;
      --mem) mem="$2"; shift 2 ;;
      --help) usage_run; return 0 ;;
      *) die "Unknown option for run: $1" ;;
    esac
  done

  require_container
  if [ "$shell_set" -eq 1 ] && [ "$cmd_override_set" -eq 1 ]; then
    die "Cannot combine --shell with --cmd"
  fi
  if [ "$cmd_override_set" -eq 1 ] && [ "${#cmd_override[@]}" -eq 0 ]; then
    die "Missing command after --cmd"
  fi
  if [ "$cmd_override_set" -eq 1 ] && [ "${#cmd_override[@]}" -eq 1 ]; then
    case "${cmd_override[0]}" in
      *[[:space:]]*) cmd_override=("$DEFAULT_LOGIN_SHELL" "-lc" "${cmd_override[0]}") ;;
    esac
  fi
  if [ "$auth" -eq 1 ] && [ "$online" -eq 0 ]; then
    die "--auth requires --online"
  fi
  if [ "$install_runtime" -eq 1 ] && [ -z "$runtime" ]; then
    die "--install-runtime requires --runtime"
  fi

  if [ -z "$workdir" ]; then
    workdir="$PWD"
  fi
  if [ ! -d "$workdir" ]; then
    die "Workdir not found: $workdir"
  fi
  workdir="$(CDPATH= cd -- "$workdir" && pwd)"

  [ -n "$image" ] || image="$DEFAULT_IMAGE"
  image="$(image_ref_for_runtime "$image")"
  warn_legacy_compat_image_usage "$image"
  if [ -z "$name" ] && [ "$temp" -eq 0 ]; then
    name="$(default_name "$DEFAULT_NAME_PREFIX" "$workdir")"
  fi
  if [ "$install_runtime" -eq 1 ] && [ "$runtime" = "claude" ] && [ -z "$mem" ] && { [ "$temp" -eq 1 ] || [ -z "$name" ] || ! container_exists "$name"; }; then
    mem="$CLAUDE_MIN_INSTALL_MEM"
  fi
  if [ "$temp" -eq 0 ] && [ -n "$name" ] && container_exists "$name" && { [ -n "$cpu" ] || [ -n "$mem" ]; }; then
    die "--cpu and --mem only apply when creating a new container. Use ${CLI_NAME} upgrade --name $name${image:+ --image $image}${cpu:+ --cpu $cpu}${mem:+ --mem $mem} to recreate the container with updated resources"
  fi
  if [ "${#runtime_config_entries[@]}" -gt 0 ]; then
    runtime_config_json="$(runtime_config_json_from_entries "${runtime_config_entries[@]}")"
  else
    runtime_config_json='{}'
  fi

  RUN_SELECTED_RUNTIME="$runtime"
  RUN_INSTALL_RUNTIME="$install_runtime"
  RUN_SYNC_RUNTIME_AUTH=0
  RUN_SYNC_POST_RUNTIME_AUTH=0
  RUN_FORCE_RUNTIME_AUTH=0
  RUN_LOCAL_MODEL_PREFLIGHT=0
  RUN_UPDATE_CODEX=0
  RUN_EFFECTIVE_MODE="local"
  RUN_REQUESTED_IMAGE="$image"
  RUN_RUNTIME_CONFIG_JSON="$runtime_config_json"
  if [ "$online" -eq 1 ]; then
    RUN_EFFECTIVE_MODE="online"
    RUN_SYNC_RUNTIME_AUTH=1
    RUN_SYNC_POST_RUNTIME_AUTH=1
    RUN_FORCE_RUNTIME_AUTH="$auth"
  elif [ "$shell" -eq 0 ] && [ "${#cmd_override[@]}" -eq 0 ]; then
    RUN_LOCAL_MODEL_PREFLIGHT=1
  fi
  if [ "$update" -eq 1 ]; then
    RUN_UPDATE_CODEX=1
  fi

  run_mode "$name" "$image" "$temp" "$shell" "$online" "$auth" "$update" "$cpu" "$mem" "$read_only" "$workdir" "$reset_config" "$runtime_config_json" "$model_override" ${cmd_override[@]+"${cmd_override[@]}"}
}

auth_cmd() {
  local name=""
  local image="$DEFAULT_IMAGE"
  local runtime="$DEFAULT_RUNTIME"

  while [ $# -gt 0 ]; do
    case "$1" in
